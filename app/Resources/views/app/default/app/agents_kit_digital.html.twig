{% extends 'app/default/app.html.twig' %}

{% set entity = 'lead' %}
{% set folder = 'app' %}

{% block title %} {{ parent() }} &bull; Agentes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- pagination css -->
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/pagination.css') }}" type="text/css" />
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/lists.css') }}" type="text/css" />
    <style>
        .pagination li.next a{
            background: url("/assets/images/app/{{ config.app_skin }}/icon_pagination_next.png");
        }
        .pagination li.previous a{
            background: url("/bundles/framework/images/app/{{ config.app_skin }}/icon_pagination_prev.png");
        }
    </style>
{% endblock %}

{% block body %}

    <div class="container-fluid">

        <div class="row">
            <div class="col-md-10 offset-1 my-4 p-2 rounded-3 bg-light font-weight-bold">
                Agentes
            </div>
        </div>

        <div class="row">
            <div class="col-md-10 offset-md-1">

                {% if session.alert %}
                    <div class="row" id="messages">
                        <div class="col-12">
                            <div class="alert alert-{{ session.alert.type }}">
                                {{ session.alert.message|raw }}
                            </div>
                        </div>
                    </div>
                    {{ deleteMessages() }}
                {% endif %}

                <div class="row no-gutters justify-content-center">
                    <div class="col-sm-12 col-md-2">
                        <button type="button" class="btn btn-info item-mail" data-item="/mail_creator_digital_kit">Crear Mail Kit Digital</button>
                    </div>
                </div>
                <div class="row no-gutters justify-content-between">
                    <div class="col-sm-12 col-md-2">
                        <button type="button" class="btn btn-info item-add" data-item="/{{ folder }}/{{ entity }}/edit/0">Añadir agente</button>
                    </div>
                    <div class="col-auto p-0">
                        {% include 'app/default/common/list_filters.twig' %}
                    </div>
                </div>
                {% include 'app/default/common/list_pagination.twig' %}

                <div class="row">
                    <div class="col-12">

                        <table class="table table-hover table-condensed">
                            <thead>
                            <tr>
                                <th>
                                    {% set column_field = 'id' %}
                                    {% set column_name = '#' %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>
                                <th>
                                    {% set column_field = 'name' %}
                                    {% set column_name = 'Nombre del agente' %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>
                                <th>
                                    {% set column_field = 'email' %}
                                    {% set column_name = 'Email' %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>
                                <th>
                                    {% set column_field = 'customer' %}
                                    {% set column_name = 'Cliente' %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>
                                <th>
                                    {% set column_field = 'send' %}
                                    {% set column_name = 'Enviar' %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>
                                <th>
                                    {% set column_field = 'blocked' %}
                                    {% set column_name = 'Bloq.' %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>
                                <th><span class="titleItem itemOptions" title="Opciones">Opciones</span></th>
                            </tr>
                            </thead>
                            <tbody>
                            {% if res %}
                                {% for item in res %}
                                    <tr>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.id }}</td>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.name|raw }}</td>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.email|raw }}</td>
                                        <td class="item-edit text-center" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}" style="text-align: center;">{% if(item.customer) %}<span class="{{ icon_active }}"></span>{% else %}<span class="{{ icon_unactive }}"></span>{% endif %}</td>
                                        <td class="item-edit text-center" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}" style="text-align: center;">{% if(item.send) %}<span class="{{ icon_active }}"></span>{% else %}<span class="{{ icon_unactive }}"></span>{% endif %}</td>
                                        <td class="item-edit text-center" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}" style="text-align: center;">{% if(item.blocked) %}<span class="{{ icon_active }}"></span>{% else %}<span class="{{ icon_unactive }}"></span>{% endif %}</td>
                                        <td>
                                            <span data-item="/{{ folder }}/{{ entity }}/delete/{{ item.id }}" class="item-delete" aria-hidden="true" style="text-decoration: none" title="Eliminar">
                                                <i class="{{ icon_delete }}" aria-hidden="true" title="Eliminar"></i>
                                            </span>
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% else %}
                                    <tr><td colspan="5">Agente no encontrado</td></tr>
                            {% endif %}
                        </table>
                    </div>
                </div>

            </div>{#<div class="col-md-10 offset-md-1">#}
        </div>{#<div class="row">#}

    </div>{#<div class="container-fluid">#}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript" src="/bundles/framework/js/app/default/pagination.js"></script>
    <script type="text/javascript" src="/bundles/framework/js/app/default/messaging.js"></script>
    <script type="text/javascript" src="/bundles/framework/js/app/default/lists.js"></script>
    <script>
    $(document).ready(function(){

    });
    (function($) {
    'use strict';

    })(jQuery);
    </script>

{% endblock %}