{# Icons for font awesome 5.15 #}
{% set step = 'fas fa-shoe-prints' %}
{% set sign_in = 'fas fa-sign-in-alt' %}

{# Colors for twig && CSS #}
{% set white_color = 'hsla(0, 0%, 100%, 1)' %} {# #FFFFFF * #}
{% set black_color = 'hsla(0, 0%, 0%, 1)' %} {# #000000 * #}
{% set red_color = 'hsla(0, 100%, 50%, 1)' %} {# #FF0000 * #}
{% set primary_color = 'hsla(0, 0%, 0%, 1)' %} {# #000000 * Black #}
{% set secondary_color = 'hsla(0, 0%, 34%, 1)' %} {# #575757 * Grey #}
{% set tertiary_color = 'hsla(0, 0%, 0%, 1)' %} {# #000000 * Black #}
{% set cuartiary_color = 'hsla(0, 0%, 90%, 1)' %} {# #575757 * Light grey #}
{% set highlight_color = 'hsla(212, 75%, 35%, 1)' %} {# #16559C * Blue #}
{% set primary_background = 'hsla(0, 0%, 100%, 1)' %} {# #FFFFFF * White #}
{% set secondary_background = 'hsla(0, 0%, 85%, 1)' %} {# #CCCCCC * Grey #}
{% set tertiary_background = 'hsla(0, 0%, 99%, 1)' %} {# #F2F2F2 * Light grey #}

{% set box_border_radius = '0.35rem' %}
{% set button_border_radius = '0.35rem' %}

{% set general_font_size = '1rem' %}
{% set title_1_font_size = '1.37rem' %}
{% set title_2_font_size = '1.1rem' %}

{# for a hrefs #}
{% set site_url = env.protocol~'://'~env.domain %}

{% set facebook = 'fab fa-facebook-square' %}
{% set linkedin = 'fab fa-linkedin-in' %}
{% set youtube = 'fab fa-youtube' %}
{% set twitter = 'fab fa-twitter' %}
{% set instagram = 'fab fa-instagram' %}
{% set pinterest = 'fab fa-pinterest' %}
{% set mail = 'far fa-envelope' %}
{% set whatsapp = 'fab fa-whatsapp' %}
{% set phone = 'fas fa-phone' %}

<!DOCTYPE html>
<html lang="{{ session[config['cookies_prefix']~'_locale'] }}" xml:lang="{{ session[config['cookies_prefix']~'_locale'] }}" prefix="og: https://ogp.me/ns#">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="content-type" content="text/html; charset=UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />

    <meta name="author" content="{{ config.web_meta_author }}" />

    {% block seo_meta %}{% endblock %}

    <link rel="profile" href="http://gmpg.org/xfn/11" />
    {#<link rel="pingback" href="{{ site_url }}/xmlrpc.php">#}

    <meta name="description" content="{% block metadescription %}{% endblock %}" />
    <meta name="robots" content="{% block metarobots %}{% endblock %}" />

    <meta name="keywords" content="{{ config.web_keywords }}" />
    <meta name="copyright" content="{{ config.web_copy_right }}" />
    <meta name="language" content="{{ session[config['cookies_prefix']~'_locale'] }}" />
    <meta name="rating" content="general" />
    <meta name="security" content="public" />
    <meta name="distribution" content="global" />
    <meta name="country" content="{{ config.meta_country }}" />
    <meta name="geo.region" content="{{ config.web_meta_geo_region }}" />
    <meta name="geo.country" content="{{ config.web_meta_geo_country }}" />
    <meta name="tgn.nation" content="{{ config.web_meta_geo_country }}" />

    {% block rel_alternate_links %}{% endblock %}

    <link rel="alternate" type="application/rss+xml" title="{{ config.web_name }} – {{ config.web_description }} » Feed" href="{{ site_url }}/feed" />

    {% if env.env_env == 'prod' %}
        <!-- Google tag (gtag.js) -->
