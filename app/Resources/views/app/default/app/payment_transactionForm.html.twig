{% extends 'app/' ~ config.app_skin ~ '/app.html.twig' %}

{% set entity = 'payment_transaction' %}

{% block title %} {{ parent() }} &bull; {% if (data.action == 'delete') %}{{ lang.PAYMENT_TRANSACTION_DELETE }}{% elseif (data.action == 'edit') or data.action == 'add' %}{{ lang.PAYMENT_TRANSACTION_EDIT }}{%  endif %}{% endblock %}

{% block body %}

<div class="container-fluid mb-4">

    <a href="#" id="topofthepage"></a>

    <div class="col-md-8 offset-md-2 col-sm-12 my-4 p-2 rounded-3 font-weight-bold {% if (data.action == 'delete') %}is_delete{%  else %} bg-light{%  endif %}">
        {% if (data.action == 'delete') %}
            {{ lang.PAYMENT_TRANSACTION_DELETE }}
        {% elseif (data.action == 'edit') %}
            {{ lang.PAYMENT_TRANSACTION_EDIT }}
        {% elseif  (data.action == 'add') %}
            {{ lang.PAYMENT_TRANSACTION_ADD }}
        {%  endif %}
        : {{ reg.name }}
    </div>

    <div class="row">
        <div class="col-md-10 col-sm-12 mx-auto">

            <form id="item-form"
                  method="post"
                  role="form"
                  enctype="multipart/form-data"
            >

                <div class="row">
                    <div class="col-md-10 col-sm-12 mx-auto">

                        <div id="box-result">
                            <div class="alert">
                            </div>
                        </div>

                        <div class="card">

                            <div class="card-header">
                                <ul class="nav nav-tabs card-header-tabs" id="tabs-list" role="tablist">
                                    <li class="nav-item">
                                        <a class="nav-link active"
                                           id="details-tab"
                                           href="#tab-details"
                                           role="tab"
                                           aria-controls="details"
                                           aria-selected="true">
                                            {{ lang.PAYMENT_TRANSACTION_TAB_DETAILS }}
                                        </a>
                                    </li>
                                    {#
                                    {% if (data.action != 'add') %}
                                        {% if user_group == '1' or user_group == '2' %}
                                            <li class="nav-item">
                                                <a class="nav-link"
                                                   id="register-tab"
                                                   href="#tab-register"
                                                   role="tab"
                                                   aria-controls="register"
                                                   aria-selected="false">
                                                    {{ lang.PAYMENT_TRANSACTION_TAB_REGISTER }}
                                                </a>
                                            </li>
                                        {% endif %}
                                    {% endif %}
                                    #}
                                </ul>
                            </div>

                            <div class="card-body">

                                {# This shines in all tab-content #}
                                {#
                                {% if data.action != 'add' and not reg.active %}
                                    <div class="row">
                                        <div class="col-9 mx-auto card-title-notactive">
                                            {{ lang.PAYMENT_TRANSACTION_NOT_ACTIVE }}
                                        </div>
                                    </div>
                                {% endif %}
                                #}

                                <div class="tab-content mt-3">

                                    <div class="tab-pane fade show active p-3 {% if ( data.action == 'delete' ) or ( data.action == 'edit' and reg.active == '0') %}reg_not_active{% else %}reg_active{% endif %}" id="tab-details" role="tabpanel">

                                        {#<h5 class="card-title text-center">{{ lang.PAYMENT_TRANSACTION_TAB_DETAILS }}</h5>#}

                                        <div class="row">
                                            <div class="col-md-12">

                                                <div class="row">
                                                    <div class="col-3 offset-1">
                                                        <label class="" for="account">{{ lang.PAYMENT_TRANSACTION_ACCOUNT }}:</label>
                                                    </div>
                                                    <div id="account" class="col-5">
                                                        {{ reg.account }} - {{ reg.account | getAccountName }}
                                                    </div>
                                                </div>
                                                <span id="accountAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_ACCOUNT_DESC }}</span>
                                                <input type="hidden" name="account" value="{{ reg.account }}">

                                                <div class="row">
                                                    <div class="col-3 offset-1">
                                                        <label class="" for="account_payment_method">{{ lang.PAYMENT_TRANSACTION_ACCOUNT_PAYMENT_METHOD }}:</label>
                                                    </div>
                                                    <div id="account_payment_method" class="col-5">
                                                        {{ reg.account_payment_method }} - {{ reg.account_payment_method | getAccountPaymentMethodName }}
                                                    </div>
                                                </div>
                                                <span id="accountAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_ACCOUNT_PAYMENT_METHOD_DESC }}</span>
                                                <input type="hidden" name="account_payment_method" value="{{ reg.account_payment_method }}">

                                                <div class="row">
                                                    <div class="col-3 offset-1">
                                                        <label class="" for="origin">{{ lang.PAYMENT_TRANSACTION_DESTINATION }}:</label>
                                                    </div>
                                                    <div id="origin" class="col-5">
                                                        {{ reg.origin }}
                                                    </div>
                                                </div>
                                                <span id="dateRegAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_DESTINATION_DESC }}</span>
                                                <input type="hidden" name="date_reg" value="{{ reg.date_reg }}">

                                                {% if reg.quote %}
                                                    <div class="row">
                                                        <div class="col-3 offset-1">
                                                            <label class="" for="quote">{{ lang.PAYMENT_TRANSACTION_QUOTE }}:</label>
                                                        </div>
                                                        <div id="quote" class="col-5">
                                                            {{ reg.quote }}
                                                        </div>
                                                    </div>
                                                    <span id="quoteAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_QUOTE_DESC }}</span>
                                                    <input type="hidden" name="quote" value="{{ reg.quote }}">
                                                {% else %}
                                                    <div class="row">
                                                        <div class="col-3 offset-1">
                                                            <label class="" for="funding">{{ lang.PAYMENT_TRANSACTION_FUNDING }}:</label>
                                                        </div>
                                                        <div id="funding" class="col-5">
                                                            {{ reg.funding }}
                                                        </div>
                                                    </div>
                                                    <span id="fundingAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_FUNDING_DESC }}</span>
                                                    <input type="hidden" name="funding" value="{{ reg.quote }}">
                                                {% endif %}

                                                <div class="row">
                                                    <div class="col-3 offset-1">
                                                        <label class="" for="date_reg">{{ lang.PAYMENT_TRANSACTION_DATE }}:</label>
                                                    </div>
                                                    <div id="date_reg" class="col-5">
                                                        {{ reg.date_reg | date("d-m-Y H:i:s") }}
                                                    </div>
                                                </div>
                                                <span id="dateRegAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_DATE_DESC }}</span>
                                                <input type="hidden" name="date_reg" value="{{ reg.date_reg }}">

                                                <div class="row">
                                                    <div class="col-3 offset-1">
                                                        <label class="" for="payment_type">{{ lang.PAYMENT_TRANSACTION_PAYMENT_TYPE }}:</label>
                                                    </div>
                                                    <div id="payment_type" class="col-5">
                                                        {{ reg.payment_type | getPaymentTypeName }}
                                                    </div>
                                                </div>
                                                <span id="paymentTypeAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_PAYMENT_TYPE_DESC }}</span>
                                                <input type="hidden" name="payment_type" value="{{ reg.payment_type }}">

                                                <div class="row">
                                                    <div class="col-3 offset-1">
                                                        <label class="" for="result">{{ lang.PAYMENT_TRANSACTION_RESULT }}:</label>
                                                    </div>
                                                    <div id="result" class="col-5">
                                                        {{ reg.result }}
                                                    </div>
                                                </div>
                                                <span id="resultAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_RESULT_DESC }}</span>
                                                <input type="hidden" name="result" value="{{ reg.result }}">

                                                <div class="row">
                                                    <div class="col-3 offset-1">
                                                        <label class="" for="event_id">{{ lang.PAYMENT_TRANSACTION_EVENT }}:</label>
                                                    </div>
                                                    <div id="event_id" class="col-5">
                                                        <pre>{{ reg.event_id }}</pre>
                                                    </div>
                                                </div>
                                                <span id="eventIdAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_EVENT_DESC }}</span>
                                                <input type="hidden" name="event_id" value="{{ reg.event_id}}">

                                                <div class="row">
                                                    <div class="col-3 offset-1">
                                                        <label class="" for="origin_id">{{ lang.PAYMENT_TRANSACTION_ORIGIN_ID }}:</label>
                                                    </div>
                                                    <div id="origin_id" class="col-5">
                                                        <pre>{% if reg.origin_id %}{{ reg.origin_id }}{% else %}{{ lang.PAYMENT_TRANSACTION_ORIGIN_STARTER }}{% endif %}</pre>
                                                    </div>
                                                </div>
                                                <span id="originIdAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_ORIGIN_ID_DESC }}</span>
                                                <input type="hidden" name="origin_id" value="{{ reg.origin_id}}">

                                                <div class="row">
                                                    <div class="col-3 offset-1">
                                                        <label class="" for="transaction_id">{{ lang.PAYMENT_TRANSACTION_KEY }}:</label>
                                                    </div>
                                                    <div id="transaction_id" class="col-5">
                                                        {{ reg.transaction_id }}
                                                    </div>
                                                </div>
                                                <span id="transactionIdAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_KEY_DESC }}</span>
                                                <input type="hidden" name="transaction_id" value="{{ reg.transaction_id }}">

                                                <div class="row">
                                                    <div class="col-3 offset-1">
                                                        <label class="" for="transaction">{{ lang.PAYMENT_TRANSACTION_TRANSACTION }}:</label>
                                                    </div>
                                                    <div id="transaction" class="col-8">
                                                        <pre>{{ reg.transaction }}</pre>
                                                    </div>
                                                </div>
                                                <span id="transactionAriaDesc" class="d-none">{{ lang.PAYMENT_TRANSACTION_TRANSACTION_DESC }}</span>
                                                <input type="hidden" name="transaction" value="{{ reg.transaction }}">

                                            </div>{# <div class="col-md-8 offset-md-2"> #}
                                        </div>{# <div class="row"> #}

                                    </div>{# <div class="tab-pane fade show active p-3" id="tab-details" role="tabpanel"> #}
                                    {#
                                    {% if (data.action != 'add') %}
                                        {% if user_group == '1' or user_group == '2' %}

                                            <div class="tab-pane fade show p-3 {% if reg.active %}reg_active{% else %}reg_not_active{% endif %}" id="tab-register" role="tabpanel">

                                            {#<h5 class="card-title text-center">{{ lang.LANG_TEXT_TAB_REGISTER }}</h5>

                                            <div class="col-9 mx-auto">
                                            <div class="row">

                                            <div class="form-group" style="width: 100%;">
                                                <label class="control-label" for="createdby">{{ lang.APP_CREATED_BY }}:</label>
                                                {{ reg.createdby }}
                                            </div>

                                            <div class="form-group" style="width: 100%;">
                                                <label class="control-label" for="createddate">{{ lang.APP_CREATED_DATE }}:</label>
                                                {{ reg.createddate }}
                                            </div>

                                            <div class="form-group" style="width: 100%;">
                                                <label class="control-label" for="updatedby">{{ lang.APP_UPDATED_BY }}:</label>
                                                {{ reg.updatedby }}
                                            </div>

                                            <div class="form-group" style="width: 100%;">
                                                <label class="control-label" for="updateddate">{{ lang.APP_UPDATED_DATE }}:</label>
                                                {{ reg.updateddate }}
                                            </div>

                                            </div>{# <div class="row">
                                            </div>{# <div class="col-9 mx-auto">

                                            </div>{# <div class="tab-pane fade show p-3" id="tab-register" role="tabpanel">

                                        {% endif %}
                                    {% endif %}
                                    #}
                                </div>{# <div class="tab-content mt-3"> #}

                            </div>{# <div class="card-body"> #}
                        </div>{# <div class="card"> #}

                    </div>{# <div class="col-8 mx-auto"> #}
                </div>{# <div class="row"> #}

                <div class="row">
                    <div class="col-12 my-4 text-center">
                        <button type="button" name="btn_submit" id="btn_submit" class="btn btn-primary" value="1">{% if (data.action == 'delete') %}{{ lang.DELETE }}{% elseif (data.action == 'edit') or data.action == 'add' %}{{ lang.SAVE }}{%  endif %}</button>
                        <button type="button" name="btn_cancel" id="btn_cancel" class="btn btn-info" formnovalidate>{{ lang.BACK_TO_LIST }}</button>
                    </div>
                </div>
                <input type="hidden" name="id" value="{{ reg.id }}">

                {# Filters #}
                {% for filter_name, filter_data in filters %}
                    {% for filter_data_key, filter_data_data in filter_data %}
                        <input type="hidden" name="filters[{{ filter_name }}][{{ filter_data_key }}]" id="filter_{{ filter_name }}_{{ filter_data_key }}" value="{{ filter_data_data }}" />
                    {% endfor %}
                {% endfor %}
                {# Pagination #}
                {% for key, value in pagination %}
                    <input type="hidden" name="pagination[{{ key }}]" id="{{ key }}" value="{{ value }}" />
                {% endfor %}

                <input type="hidden" name="auth_token" value="{{ data.auth_token }}" />

            </form>

        </div>{# <div class="col-md-8 offset-md-2"> #}
    </div>{# <div class="row">#}

</div>{# <div class="container-fluid mb-4">#}

<div class="clear"></div>

{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/form.css') }}" type="text/css" />
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript">
        var folder = '{{ session[config['cookies_prefix']~'_folder'] }}';
        var entity = '{{ entity }}';
        var action = '{{ data.action }}';
        var cancel = '{{ cancel }}';
        var reg_id = '{{ reg.id }}';
        var l_errors_found = '{{ lang.ERRORS_FOUND }}';
        var l_form_has_errors = '{{ lang.ERRORS_FORM }}';
    </script>
    <script type="text/javascript" src="/assets/js/app/{{ config.app_skin }}/forms.js"></script>
    <script type="text/javascript" src="/assets/js/app/{{ config.app_skin }}/scrool-to-top.js"></script>
{% endblock %}
