{% extends 'web/' ~ config.website_skin ~ '.html.twig' %}

{% set this_page = 'blog' %}{# -> WEB_BREADCRUMPS_ + this_page #}
{% set this_route = '/blog' %}
{% set this_page_title = lang.WEB_TITLE_BLOG_HOME %}
{% set this_page_metadescription = lang.WEB_METADESCRIPTION_BLOG_HOME %}

{% block seo_meta %}
	<meta property="og:locale" content="{{ session[config['cookies_prefix']~'_locale'] }}" />
	<meta property="og:type" content="website" />{# article #}
	<meta property="og:title" content="{{ this_page_title }} - {{ config.web_name }}" />
	<meta property="og:description" content="{{ this_page_metadescription }}" />
	<meta property="og:url" content="{{ site_url ~ this_route }}" />
	<meta property="og:site_name" content="{{ config.web_name }}" />
	<meta property="og:updated_time" content="2024-10-30T12:00:00+00:00" />
	{#<meta property="og:image" content="{{ site_url }}/documents/blog/image.jpg" />#}
	{#<meta property="og:image:secure_url" content="{{ site_url }}/documents/blog/image.jpg" />#}
	{#<meta property="og:image:width" content="1280" />#}
	{#<meta property="og:image:height" content="504" />#}
	{#<meta property="og:image:alt" content="{{ lang.WEB_CERTIFICATIONS_HERO_TITLE }}" />#}
	{#<meta property="og:image:type" content="image/jpeg" />#}
	<meta property="article:publisher" content="{{ config.company_facebook }}">
	<meta property="article:author" content="{{ config.company_facebook }}">
	<meta property="article:published_time" content="2024-10-31T12:00:00+00:00" />
	<meta property="article:modified_time" content="2024-10-31T12:00:00+00:00" />
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content="{{ this_page_title }} - {{ config.web_name }}" />
	<meta name="twitter:description" content="{{ this_page_metadescription }}" />
	{#<meta name="twitter:image" content="{{ site_url }}/documents/blog/image.jpg" />#}
	<link rel="shortlink" href="{{ site_url ~ this_route }}">
{% endblock %}

{% block metadescription %}{{ this_page_metadescription }}{% endblock %}
{% block metarobots %}index, follow{% endblock %}

{% block rel_alternate_links %}
	{{ data.canonical | replace({'%this_route%': this_route }) | raw }}
	{{ data.alternate_langs | replace({'%this_route%': this_route }) | raw }}
{% endblock %}

{% block ld_json %}
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": "Blog sobre automatizacion de procesos empresariales con IA - {{ env.web_name }}",
			"url": "{{ env.protocol }}://{{ env.domain }}/blog",
			"description": "Explora artículos, guías y consejos sobre automatizaciones. Aprende como ganar tiempo automatizando las tareas tediosas, descubre mitos, tips prácticos y casos reales que ayudarán a tu negocio a crecer.",
			"inLanguage": "es",
			"isPartOf": {
				"@type": "WebSite",
				"name": "{{ config.web_name }}",
				"url": "{{ env.protocol }}://{{ env.domain }}"
			},
			"primaryImageOfPage": {
				"@type": "ImageObject",
				"url": "{{ env.protocol }}://{{ env.domain }}/assets/images/web/default/bands/blog/blog_hero.png",
				"caption": "Blog de {{ config.web_name }}"
			},
			"breadcrumb": {
				"@type": "BreadcrumbList",
				"itemListElement": [
					{
						"@type": "ListItem",
						"position": 1,
						"name": "Inicio",
						"item": "{{ env.protocol }}://{{ env.domain }}"
					},
					{
						"@type": "ListItem",
						"position": 2,
						"name": "Blog",
						"item": "{{ env.protocol }}://{{ env.domain }}/blog"
					}
				]
			},
			"mainEntity": {
				"@type": "Service",
				"name": "Blog de {{ config.web_name }}",
				"description": "Publicamos contenidos educativos y divulgativos sobre automatización de procesos empresariales con IA. Nuestro blog es un recurso abierto para profesionales, empresas y administraciones.",
				"provider": {
					"@type": "Organization",
					"name": "{{ config.web_name }}",
					"url": "{{ env.protocol }}://{{ env.domain }}"
				},
				"serviceType": "Publicación de contenidos informativos y educativos",
				"areaServed": "ES",
				"availableChannel": {
					"@type": "ServiceChannel",
					"serviceLocation": {
						"@type": "VirtualLocation",
						"url": "{{ env.protocol }}://{{ env.domain }}/blog"
					},
					"servicePhone": {
						"@type": "ContactPoint",
						"contactType": "Atención al cliente",
						"telephone": "+34 983 10 59 08"
					},
					"serviceSmsNumber": {
						"@type": "ContactPoint",
						"contactType": "Correo electrónico",
						"email": "info@{{ env.protocol }}://{{ env.domain }}"
					},
					"availableLanguage": ["es", "en"],
					"serviceUrl": "{{ env.protocol }}://{{ env.domain }}/contacto"
				},
				"audience": {
					"@type": "Audience",
					"audienceType": "PYMEs, Marketing, CEO, Empresas, Administraciones Públicas"
				},
				"offers": {
					"@type": "Offer",
					"priceCurrency": "EUR",
					"price": "0.00",
					"eligibleRegion": "ES",
					"url": "{{ env.protocol }}://{{ env.domain }}/blog",
					"availability": "https://schema.org/InStock"
				},
				"termsOfService": "{{ env.protocol }}://{{ env.domain }}/terminos-de-venta",
				"serviceOutput": "Artículos y recursos gratuitos sobre automatizaciones empresariales con IA.",
				"providerMobility": "static",
				"isAccessibleForFree": true
			}
		}

	</script>
{% endblock %}
{% block title %} {{ lang.WEB_TITLE_BLOG_HOME }} - {{ parent() }}{% endblock %}

{% block body %}

    <div id="blog_index_main">

		{% include 'web/' ~ config.website_skin ~ '/blog/bands/blog_hero.html.twig' %}
		<a href="#" id="topofthepage" aria-label="{{ lang.WEB_TOP_OF_THE_PAGE }}"></a>
		{% include 'web/' ~ config.website_skin ~ '/blog/bands/blog_articles_list.html.twig' %}
		{#
		{% include 'web/' ~ config.website_skin ~ '/bands/external_logos.html.twig' %}
		{% include 'web/' ~ config.website_skin ~ '/header_links.html.twig' %}
		#}

	</div>

{% endblock %}

{% block stylesheets %}
    {{ parent() }}
	{#<link href="/assets/css/web/{{ config.website_skin }}/plugins/owl/owl.carousel.min.css" rel="stylesheet">#}
	{#<link href="/assets/css/web/{{ config.website_skin }}/plugins/owl/owl.theme.default.min.css" rel="stylesheet">#}
	<link href="/assets/css/web/{{ config.website_skin }}/blog/bands/blog_hero.css" rel="stylesheet">
	<link href="/assets/css/web/{{ config.website_skin }}/blog/bands/blog_articles_list.css" rel="stylesheet">
	{#
	<link href="/assets/css/web/{{ config.website_skin }}/bands/external_logos.css" rel="stylesheet">
	<link href="/assets/css/web/{{ config.website_skin }}/header_links.css" rel="stylesheet">
	#}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
	<script type="text/javascript" src="/assets/js/web/{{ config.website_skin }}/scrool-to-top.js"></script>
{% endblock %}
