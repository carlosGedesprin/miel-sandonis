{% extends 'app/' ~ config.app_skin ~ '/emails/emailBase.html.twig' %}
{# app/Resources/views/emails/user_pass_changed.html.twig #}
{% set email_ref = 'user_pass_changed' %}

{% block body %}
<table class="container" width="600" border="0">
    <tr>
        <td style="padding-top:20px;">
            <table width="100%">
                <tr>
                    <td style="padding-top:10px; text-align:justify; text-justify:inter-word;">
                        {{ lang.MAIL_SECURITY_CHANGE_PASS_EXP | raw }}
                    </td>
                </tr>
                <tr>
                    <td style="margin-top:10px; text-align:justify; text-justify:inter-word;">
                        {{ lang.MAIL_SECURITY_CHANGE_PASS_EXP_2 | raw }}
                    </td>
                </tr>
                <tr>
                    <td style="margin-top:10px; text-align:justify; text-justify:inter-word;">
                        <a href="{{ data.confirmation_link }}">{{ lang.MAIL_SECURITY_CHANGE_PASS_LINK_TEXT | raw }}</a>.
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
{% endblock %}
