                window.location.replace("/pay_gateway/charge_pay/{{ charge.id }}");
                /*
                var $gateway = $(this).attr('data-control');
                window.location.replace("/charge_pay/" + $gateway + "/{{ reg.id }}");
                */
            });
            #}
        })(jQuery); // Avoid conflicts with other libraries
    </script>
    {% if false %}
        {# Production #}
        <script src="https://sis.redsys.es/sis/NC/redsysV2.js"></script>
    {% else %}
        {# Development #}
        <script src="https://sis-t.redsys.es:25443/sis/NC/sandbox/redsysV2.js"></script>
    {% endif %}
    <script>
        function pedido()
        {
            const d = new Date();
            // console.log((d.getSeconds()).toString(), (d.getMinutes()).toString(), (d.getHours()).toString(), (d.getDay()).toString(), (d.getMonth()).toString(), (d.getFullYear()).toString().substring(2, 2));
            const string_a = (d.getSeconds()).toString() + (d.getMinutes()).toString() + (d.getHours()).toString() + (d.getDay()).toString() + (d.getMonth()).toString()+ (d.getFullYear()).toString();
            // console.log('String', string_a);
            const pedidoOrder = string_a.toString().substring(0, 12);
            document.getElementById('order').value = pedidoOrder;
            return pedidoOrder;
        }
        //document.getElementById("timeOrder").innerHTML = pedido();

        let styleCardNumber = 'width: 150px; height: 30px; border: solid 1px red;';
        let styleExpMonth = 'width: 100px; height: 30px; border: solid 1px red;';
        let styleExpYear = 'width: 100px; height: 30px; border: solid 1px red;';
        let styleCVV = 'width: 100px; height: 30px; border: solid 1px red;';
        let stylePayButton = 'width: 100px; height: 20px; border: solid 1px red;';
        {# https://pagosonline.redsys.es/conexion-insite.html #}
        getCardInput('card-number', styleCardNumber);
        getExpirationMonthInput('expiration-month', styleExpMonth);
        getExpirationYearInput('expiration-year', styleExpYear);
        getCVVInput('cvv', styleCVV);
        getPayButton('boton', stylePayButton, '{{ lang.PAY_A_QUOTE_PAY_THIS_QUOTE }}', '356112847', '001', pedido());

        function sendResult(){
            return true;
        }
        <!-- Listener de recepción de ID de operación -->
        window.addEventListener("message", function receiveMessage(event) {
            storeIdOper(event,"token", "errorCode", sendResult);
            let token = document.getElementById('token').value;
            if ( token != '') {
                document.getElementById('formDatos').submit();
            }
        });

    </script>
{% endblock %}
