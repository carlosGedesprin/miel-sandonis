        {#<link rel="stylesheet" href="/bundles/framework/css/web/{{ config.website_skin }}/cookieconsent.css" media="print" onload="this.media='all'">#}

        {# Our css s #}
        <link href="/bundles/framework/css/main-general.css" rel="stylesheet">
        <link href="/bundles/framework/css/bootstrap-extra.css" rel="stylesheet">
        <link href="/bundles/framework/css/web/{{ config.website_skin }}/styles.css" rel="stylesheet">

        <style>
            :root {
                --white: {{ white_color }};
                --black: {{ black_color }};
                --red: {{ red_color }};

                --primary-color: {{ primary_color }};
                --secondary-color: {{ secondary_color }};
                --tertiary-color: {{ tertiary_color }};
                --cuartiary-color: {{ cuartiary_color }};
                --highlight-color: {{ highlight_color }};
                --primary-background: {{ primary_background }};
                --secondary-background: {{ secondary_background }};
                --tertiary-background: {{ tertiary_background }};

                --new-dark-blue: {{ dark_blue }};
                --new-light-blue: {{ light_blue }};

                --box-border-radius: {{ box_border_radius }};
                --button-border-radius: {{ button_border_radius }};

                --general_font_size: {{ general_font_size }};
                --title_1_font_size: {{ title_1_font_size }};
                --title_2_font_size: {{ title_2_font_size }};
            }
        </style>
        {% if env.developer == 'carlos' %}
            <link href="/assets/css/web/{{ config.website_skin }}/header_helpers.css" rel="stylesheet">
        {% endif %}
        <link href="/assets/css/web/{{ config.website_skin }}/header.css" rel="stylesheet">
        {# <link href="/bundles/framework/css/web/{{ config.website_skin }}/phone_contact.css" rel="stylesheet">
        <link href="/bundles/framework/css/web/{{ config.website_skin }}/whatsapp_button.css" rel="stylesheet"> #}
        <link href="/bundles/framework/css/web/{{ config.website_skin }}/main.css" rel="stylesheet">
        <link href="/bundles/framework/css/web/{{ config.website_skin }}/footer.css" rel="stylesheet">
    {% endblock %}

</head>
<body>

<!-- Google Tag Manager (noscript) -->
<noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NRQWH6VB" height="0" width="0" style="display:none;visibility:hidden"></iframe>
</noscript>
<!-- End Google Tag Manager (noscript) -->

<style>
    {# Styles with twig commands #}
    :root
    {
        --scroll_width: 17px;
        --header_helpers_height: {% if env.developer == 'carlos' %}40px{% else %}0px{% endif %};
        --header_helpers_width: calc( 100vw - var(--scroll_width) );
        --header_contact_height_mobile: 55px;
        --header_contact_height_desktop: 35px;
        --header_contact_top: {% if env.developer == 'carlos' %}calc( var(--header_helpers_height) + 5px ){% else %}var(--header_helpers_height){% endif %};
        --header_menu_height: 115px;
        --header_menu_top_mobile: calc(var(--header_helpers_height) + var(--header_contact_height_mobile));
        --header_menu_top_desktop: calc(var(--header_helpers_height) + var(--header_contact_height_desktop));
        --header_height_mobile: calc(var(--header_helpers_height) + var(--header_contact_height_mobile) + var(--header_menu_height));
        --header_height_desktop: calc(var(--header_helpers_height) + var(--header_contact_height_desktop) + var(--header_menu_height));
    }
    #header {
        height: var(--header_height_mobile);
    }
    #main {
        margin-top: var(--header_height_mobile);
    }
    @media (min-width: 400px) {
        #header {
            height: var(--header_height_desktop);
        }
        #main {
            margin-top: var(--header_height_desktop);
        }
    }
</style>

{% include 'web/' ~ config.website_skin ~ '/header.html.twig' %}

