{% extends 'web/' ~ config.website_skin ~ '.html.twig' %}

{% set this_page = 'blog_article' %}
{% set this_route = '/blog/' ~ article.slug %}
{% set this_page_title = lang.BLOG_TITLE_ARTICLE | replace({'%title%': article.title }) %}
{% set this_page_metadescription = article.metadescription %}
{% set path_blog_images = '/documents/blog/' %}

{% block seo_meta %}
	<meta property="og:locale" content="{{ session[config['cookies_prefix']~'_locale'] }}" />
	<meta property="og:type" content="article" />{# website #}
	<meta property="og:title" content="{{ this_page_title }} - {{ config.web_name }}" />
	<meta property="og:description" content="{{ article.metadescription }}" />
	<meta property="og:url" content="{{ site_url ~ this_route }}" />
	<meta property="og:site_name" content="{{ config.web_name }}" />
	<meta property="og:updated_time" content="2024-10-30T12:00:00+00:00" />
	<meta property="og:image" content="{{ site_url }}/documents/blog/{{ article.picture }}" />
	<meta property="og:image:secure_url" content="{{ site_url }}/documents/blog/{{ article.picture }}" />
	{#<meta property="og:image:width" content="1280" />#}
	{#<meta property="og:image:height" content="504" />#}
	<meta property="og:image:alt" content="{{ article.title }}" />
	<meta property="og:image:type" content="image/jpeg" />
	<meta property="article:publisher" content="{{ config.company_facebook }}">
	<meta property="article:author" content="{{ config.company_facebook }}">
	<meta property="article:published_time" content="{{ article.date }}T12:00:00+00:00" />
	<meta property="article:modified_time" content="{{ "now" | date('d-m-Y') }}T12:00:00+00:00" />
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content="{{ this_page_title }} - {{ config.web_name }}" />
	<meta name="twitter:description" content="{{ article.metadescription }}" />
	<meta name="twitter:image" content="{{ site_url }}/documents/blog//documents/blog/{{ article.picture }}" />
	<link rel="shortlink" href="{{ site_url ~ this_route }}">
{% endblock %}

{% block metadescription %}{{ this_page_metadescription }}{% endblock %}
{% block metarobots %}index, follow{% endblock %}

{% block rel_alternate_links %}
	{{ data.canonical | replace({'%this_route%': this_route }) | raw }}
	{{ data.alternate_langs | replace({'%this_route%': this_route }) | raw }}
{% endblock %}

{% block ld_json %}
	<script type="application/ld+json">
		{
		  "@context": "https://schema.org",
		  "@type": "Article",
		  "mainEntityOfPage": {
			"@type": "WebPage",
			"@id": "{{ this_route | trim('/', 'left') | replace({'/': '-' }) | raw  }}"
		  },
		  "headline": "{{ this_page_title }}",
		  "description": "{{ this_page_metadescription }}",
		  "image": {
			"@type": "ImageObject",
			"url": "{{ path_blog_images ~ article.picture }}",
			"width": "275px",
			"height": "172px",
			"caption": "{{ article.picture_alt_text }}"
		  },
		  "author": {
			"@type": "Organization",
			"@id": "{{ article.author.id }}",
			"name": "{{ article.author.name }}",
			"url": "{{ article.author.linkedin}}"
		  },
		  "publisher": {
			"@type": "Organization",
			"@id": "{{ env.protocol }}://{{ env.domain }}/#organization",
			"name": "{{ config.web_name }}",
			"url": "{{ env.protocol }}://{{ env.domain }}",
			"logo": {
			  "@type": "ImageObject",
			  "url": "{{ env.protocol }}://{{ env.domain }}{{ path_blog_images ~ article.picture }}",
			  "width": "275px",
			  "height": "172px"
			}
		  },
		  "datePublished": "{{ article.date }}",
		  "dateModified": "{{ article.date }}",
		  "articleSection": "{{ article.category_name }}",
		  "keywords": [
			{{ article.keywords }}
		  ],
{#
		  "about": [
			{{ABOUT_ENTITIES}}
		  ],
		  "mentions": [
			{{MENTIONS_ARRAY}}
		  ],
#}
		  "isAccessibleForFree": true,
		  "inLanguage": "es-ES",
{#
		  "educationalUse": "{{EDUCATIONAL_USE}}",
		  "teaches": [
			{{TEACHES_ARRAY}}
		  ],
#}
		  "audience": [
			  {
				"@type": "Audience",
				"audienceType": "Businesses"
			  },
			  {
				"@type": "Audience",
				"audienceType": "Public Administrations"
			  },
			  {
				"@type": "Audience",
				"audienceType": "Digital Agencies"
			  },
			  {
				"@type": "Audience",
				"audienceType": "Web Developers"
			  }
		  ],
{#
		  "wordCount": {{WORD_COUNT}},
#}
		  "articleBody": "{{ article.text | replace({'"' : ''}) | raw }}"
		}
	</script>

	{% if article_faqs %}
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "FAQPage",
				"mainEntity": [
					{% for article_faq in article_faqs %}
						{% if ( article_faq.question != '') %}
							{
								"@type": "Question",
								"name": "{{ article_faq.question | raw }}",
								"acceptedAnswer": {
									"@type": "Answer",
									"text": "{{ article_faq.reply | raw }}"
								}
							}{% if ( not loop.last ) %},{% endif %}
						{% endif %}
					{% endfor %}
				]
			}
		</script>
	{% endif %}
{% endblock %}

{% block title %} {{ article.title | raw }} - {{ parent() }}{% endblock %}

{% block body %}

    <div id="blog_article_main">

		{% include 'web/' ~ config.website_skin ~ '/blog/bands/blog_hero.html.twig' %}
		<a href="#" id="topofthepage" aria-label="{{ lang.WEB_TOP_OF_THE_PAGE }}"></a>
		{% include 'web/' ~ config.website_skin ~ '/blog/bands/blog_hero_title.html.twig' %}
		{% include 'web/' ~ config.website_skin ~ '/blog/bands/blog_article.html.twig' %}
		{% include 'web/' ~ config.website_skin ~ '/blog/bands/blog_article_faq.html.twig' %}
		{#
		{% include 'web/' ~ config.website_skin ~ '/bands/external_logos.html.twig' %}
		{% include 'web/' ~ config.website_skin ~ '/header_links.html.twig' %}
		#}

	</div>

{% endblock %}

{% block stylesheets %}
    {{ parent() }}
	{#<link href="/assets/css/web/{{ config.website_skin }}/plugins/owl/owl.carousel.min.css" rel="stylesheet">#}
	{#<link href="/assets/css/web/{{ config.website_skin }}/plugins/owl/owl.theme.default.min.css" rel="stylesheet">#}
	<link href="/assets/css/web/{{ config.website_skin }}/blog/bands/blog_hero.css" rel="stylesheet">
	<link href="/assets/css/web/{{ config.website_skin }}/blog/bands/blog_hero_title.css" rel="stylesheet">
	<link href="/assets/css/web/{{ config.website_skin }}/blog/bands/blog_article.css" rel="stylesheet">
	<link href="/assets/css/web/{{ config.website_skin }}/blog/bands/blog_article_faq.css" rel="stylesheet">
	{#
	<link href="/assets/css/web/{{ config.website_skin }}/bands/external_logos.css" rel="stylesheet">
	<link href="/assets/css/web/{{ config.website_skin }}/header_links.css" rel="stylesheet">
	#}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
	<script type="text/javascript" src="/assets/js/web/{{ config.website_skin }}/scrool-to-top.js"></script>
	<script src="/assets/js/web/{{ config.website_skin }}/faq.js"></script>
{% endblock %}
