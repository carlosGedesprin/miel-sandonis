                                    </a>
                                </div>
                            {% else %}
                                <a id="site_log_in"
                                   href="/{{ lang.WEB_LOGIN_LINK }}"
                                   class="log-icon header_action_buttons_link"
                                   title="{{ lang.WEB_LOGIN_TITLE }}">
                                    {#
                                    <div class="header_action_buttons_text">
                                        {{ lang.WEB_MENU_LOGIN }}
                                    </div>
