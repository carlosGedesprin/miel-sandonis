{% extends 'app/' ~ config.app_skin ~ '/app.html.twig' %}
{% set path_images = '/assets/images/app/'~config.app_skin~'/control_panel/' %}
{% set icons_color = '#4F4F4F' %}

{% block title %} {{ parent() }} &bull; {{ lang.dashboard_name }}{% endblock %}

{% block body %}

    <div class="row">
        <div class="col-md-12">

            <form id="control_panel_form"
                method="post"
                role="form"
                enctype="multipart/form-data"
            >
            </form>

                <div id="dashboard_agent_container">
                    <div id="dashboard_agent_header">
                        <div id="dashboard_agent_center">
                            <div id="dashboard_agent_title">
                                <h1>
                                    {% if (session[config['cookies_prefix']~'_UserGroup'] == group_super_admin ) %}
                                        {{ lang.APP_DASHBOARD_SADMIN }}
                                    {% elseif (session[config['cookies_prefix']~'_UserGroup'] == group_admin ) %}
                                        {{ lang.APP_DASHBOARD_ADMIN }}
                                    {% elseif (session[config['cookies_prefix']~'_UserGroup'] == group_staff ) %}
                                        {{ lang.APP_DASHBOARD_STAFF }}
                                    {% elseif (session[config['cookies_prefix']~'_UserGroup'] == group_customer ) %}
                                        {{ lang.APP_DASHBOARD_CUSTOMER }}
                                    {% elseif (session[config['cookies_prefix']~'_UserGroup'] == group_agent ) %}
                                        {{ lang.APP_DASHBOARD_AGENT }}
                                    {% elseif (session[config['cookies_prefix']~'_UserGroup'] == group_supervisor ) %}
                                        {{ lang.APP_DASHBOARD_SUPERVISOR }}
                                    {% elseif (session[config['cookies_prefix']~'_UserGroup'] == group_verificator_l1 ) %}
                                        {{ lang.APP_DASHBOARD_VERIFICATOR }}
                                    {% elseif (session[config['cookies_prefix']~'_UserGroup'] == group_verificator_l2 ) %}
