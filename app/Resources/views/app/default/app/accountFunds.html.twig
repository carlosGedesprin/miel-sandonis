{% extends 'app/' ~ config.app_skin ~ '/app.html.twig' %}

{% set entity = 'account_fund' %}
{% set folder = 'app' %}

{% block title %} {{ parent() }} &bull; {{ lang.ACCOUNT_FUNDS }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- pagination css -->
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/pagination.css') }}" type="text/css" />
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/lists.css') }}" type="text/css" />
    <style>
        .pagination li.next a{
            background: url("/assets/images/app/{{ config.app_skin }}/icon_pagination_next.png");
        }
        .pagination li.previous a{
            background: url("/assets/images/app/{{ config.app_skin }}/icon_pagination_prev.png");
        }
    </style>
{% endblock %}

{% block body %}

    <div class="container-fluid">

        <div class="row">
            <div class="col-md-10 offset-1 my-4 p-2 rounded-3 bg-light font-weight-bold">
                {{ lang.ACCOUNT_FUNDS }}
            </div>
        </div>

        <div class="row">
            <div class="col-md-10 offset-md-1">

                {% if session.alert %}
                    <div class="row" id="messages">
                        <div class="col-12">
                            <div class="alert alert-{{ session.alert.type }}">
                                {{ session.alert.message | raw }}
                            </div>
                        </div>
                    </div>
                    {{ deleteMessages() }}
                {% endif %}

                <div class="row no-gutters justify-content-between">
                    <div class="col-sm-12 col-md-2">
                        <button type="button" class="btn btn-info item-add" data-item="/{{ folder }}/{{ entity }}/edit/0">{{ lang.ACCOUNT_FUND_ADD }}</button>
                    </div>
                    <div class="col-auto p-0">
                        {% include 'app/' ~ config.app_skin ~ '/common/list_filters.twig' %}
                    </div>
                </div>

                <div class="row no-gutters justify-content-center">
                    <div class="col-5 font-size-13 {% if balance < 0 %}font-color-red{% else %}font-color-blue{% endif %} text-center">
                        {{ lang.ACCOUNT_FUND_BALANCE }}: {{ ( balance | raw / 100 ) | number_format(2,',','.') }}&nbsp;{{ config.web_currency }}
                    </div>
                </div>

                {% include 'app/' ~ config.app_skin ~ '/common/list_pagination.twig' %}

                <div class="row">
                    <div class="col-12">

                        <table class="table table-hover table-condensed">
                            <thead>
                            <tr>
                                <th>
                                    {% set column_field = 'id' %}
                                    {% set column_name = '#' %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>
                                <th>
                                    {% set column_field = 'date' %}
                                    {% set column_name = lang.ACCOUNT_FUND_DATE %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>
                                {% if filters['account']['value'] == '' %}
                                    <th>
                                        {% set column_field = 'account' %}
                                        {% set column_name = lang.ACCOUNT_FUND_ACCOUNT %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                {% else %}
                                    <th>
                                        {% set column_field = 'description' %}
                                        {% set column_name = lang.ACCOUNT_FUND_DESCRIPTION %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                {% endif %}
                                <th class="text-right" style="padding-right: 30px !important;">
                                    {% set column_field = 'credit' %}
                                    {% set column_name = lang.ACCOUNT_FUND_CREDIT %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>
                                <th class="text-left" style="padding-left: 30px !important;">
                                    {% set column_field = 'debit' %}
                                    {% set column_name = lang.ACCOUNT_FUND_DEBIT %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>

                                <th><span class="titleItem itemOptions" title="{{ lang.OPTIONS }}">{{ lang.OPTIONS }}</span></th>
                            </tr>
                            </thead>
                            <tbody>
                            {% if res %}
                                {% for item in res %}
                                    <tr class="item-edit-row">
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.id }}</td>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.date | date("d-m-Y") }}</td>
                                        {% if filters['account']['value'] == '' %}
                                            <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.account | getAccountName }} - {{ item.account }}</td>
                                        {% else %}
                                            <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.description }}</td>
                                        {% endif %}
                                        <td class="item-edit text-right" style="padding-right: 30px !important; color: blue;" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{% if item.credit %}{{ ( item.credit | raw / 100 ) | number_format(2,',','.') }}{% endif %}</td>
                                        <td class="item-edit text-left" style="padding-left: 40px !important; color: red;" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{% if item.debit %}{{ ( item.debit | raw / 100 ) | number_format(2,',','.') }}{% endif %}</td>
                                        {% if user_group == '1' or user_group == '2' %}
                                            <td>
                                                <span data-item="/{{ folder }}/{{ entity }}/delete/{{ item.id }}" class="item-delete" aria-hidden="true" style="text-decoration: none" title="{{ lang.DELETE }}">
                                                    <i class="{{ icon_delete }}" aria-hidden="true" title="{{ lang.DELETE }}"></i>
                                                </span>
                                            </td>
                                        {% endif %}
                                    </tr>
                                {% endfor %}
                            {% else %}
                                <tr><td colspan="5">{{ lang.ACCOUNT_NOT_FOUND }}</td></tr>
                            {% endif %}
                        </table>
                    </div>
                </div>

            </div>{#<div class="col-md-10 offset-md-1">#}
        </div>{#<div class="row">#}

    </div>{#<div class="container-fluid">#}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/pagination.js') }}"></script>
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/messaging.js') }}"></script>
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/lists.js') }}"></script>
    <script>
    $(document).ready(function(){

    });
    (function($) {

        'use strict';

    })(jQuery);
    </script>

{% endblock %}