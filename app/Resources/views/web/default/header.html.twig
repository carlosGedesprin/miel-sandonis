                <a id="menu_toggle" href="#" class="icon" onclick="toggleMenu()" title="{{ lang.WEB_MENU_TOGGLE_NAVIGATION }}">
                    <i id="icon_bars" class="fa fa-bars"></i>
                </a>
            </div>

        </div>
    </section>


</header>