{% extends 'app/' ~ config.app_skin ~ '/emails/emailBase.html.twig' %}
{# app/Resources/views/emails/web_contact.html.twig #}
{% set email_ref = 'web_contact' %}

{# A nosotros #}

{% block body %}
    <tr>
        <td style="margin-top: 10px; text-align: left;">
            <table border="0" cellspacing="0" cellpadding="0" width="800">
                <tr>
                    <td class="mail_text">
                        {{ lang.MAIL_CONTACT_MAIL_TITLE }}
                    </td>
                </tr>
                <tr>
                    <td class="mail_text" style="padding-top: 20px">
                        {{ lang.MAIL_CONTACT_MAIL_FROM }}  {{ data.contact_name }}
                    </td>
                </tr>
                <tr>
                    <td class="mail_text" style="padding-top: 20px">
                        {{ lang.MAIL_CONTACT_MAIL_EMAIL }}  {{ data.contact_email }}
                    </td>
                </tr>
                <tr>
                    <td class="mail_text" style="padding-top: 20px">
                        {{ lang.MAIL_CONTACT_MAIL_PHONE }}  {{ data.contact_phone }}
                    </td>
                </tr>
                <tr>
                    <td class="mail_text">
                        {{ lang.MAIL_CONTACT_MAIL_NOTES }}
                        <p class="mail_text_box">
                            {{ data.contact_notes | raw }}
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
{% endblock %}
