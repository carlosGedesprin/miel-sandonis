
<header id="header">
    {% if env.developer == 'carlos' %}
        {% include 'web/' ~ config.website_skin ~ '/header_helpers.html.twig' %}
    {% endif %}

    <section id="header_contact">
        <div id="header_contact_band">
            <div id="header_contact_band_phone" class="header_contact_band_item">
                <i aria-hidden="true" class="{{ phone }} header-contact-icon" title="Llámanos y te resolvemos tus dudas"></i>
                &nbsp;/&nbsp;
                <a id="wa-link" href="https://api.whatsapp.com/send?phone=601556175" title="Contacta con nosotros por WhatsApp" target="_blank" class="header_contact_link">
                    <i aria-hidden="true" title="Contacta con nosotros por WhatsApp" class="{{ whatsapp }} header-contact-icon"></i>&nbsp;{% if session[config['cookies_prefix']~'_locale'] == 'es' %}{{ config.web_info_phone }}{% else %}+44 749 60 57 196{% endif %}
                </a>
            </div>
            <div id="header_contact_band_email" class="header_contact_band_item">
                <i aria-hidden="true" class="{{ mail }} header-contact-icon"></i>&nbsp;
                <a id="ph-link" href="mailto:info@altiraautomations.com" title="Envíanos un mensaje por email" target="_blank" class="header_contact_link">
                    {{ config.web_info_email }}
                </a>
            </div>
        </div>
        <div id="header_contact_langs">
            {{ data.langs | replace({'%this_route%': this_route }) | raw }}
        </div>
    </section>
    <section id="header_menu">
        <div id="header_menu_content">

            <div id="header_menu_site_logo">
                <a id="header_menu_site_logo_link" class="navbar-brand" href="/" title="{{ config.web_name_long }}">
                    <img id="header_menu_site_logo_img"
                         src="/assets/images/web/{{ config.website_skin }}/logo_with_text_hor.png"
                         alt="{{ lang.WEB_MENU_LOGO_ALT_TEXT | raw }}" />
                </a>
            </div>
            <div id="header_menu_menu" class="topnav">
                <ul id="nav_left_items" class="nav_left_items">
                    {% if env.env_env == 'dev' %}
                        <li class="menu_item {% if this_page == 'templates' %}active{% endif %}">
                            <a class="menu_link"
                               href="/templates"
                               title="Templates">
                                Plantillas
                            </a>
                        </li>
                    {% endif %}
                    <li class="menu_item {% if this_page == 'solutions' %}active{% endif %}">
                        <a class="menu_link"
                           href="/{{ lang.WEB_MENU_SOLUTIONS_LINK }}"
                           title="{{ lang.WEB_MENU_SOLUTIONS_TITLE }}">
                            {{ lang.WEB_MENU_SOLUTIONS | raw }}
                        </a>
                    </li>
                    <li class="menu_item {% if this_page == 'about_us' %}active{% endif %}">
                        <a class="menu_link"
                           href="/{{ lang.WEB_MENU_ABOUT_US_LINK }}"
                           title="{{ lang.WEB_MENU_ABOUT_US_TITLE }}">
                            {{ lang.WEB_MENU_ABOUT_US | raw }}
                        </a>
                    </li>
                    <li class="menu_item {% if this_page == 'blog' %}active{% endif %}">
                        <a class="menu_link"
                                {% if env.country == 'ES' %}
                                    href="/{{ lang.WEB_MENU_BLOG_LINK }}"
                                {% else %}
                                    href="/{{ lang.WEB_MENU_BLOG_LINK }}"
                                {% endif %}
                           title="{{ lang.WEB_MENU_BLOG_TITLE }}">
                            {{ lang.WEB_MENU_BLOG }}
                        </a>
                    </li>
                    <li class="menu_item {% if this_page == 'contactus' %}active{% endif %}">
                        <a class="menu_link"
                           href="/{{ lang.WEB_MENU_CONTACT_LINK }}"
                           title="{{ lang.WEB_TITLE_CONTACT }}">
                            {{ lang.WEB_MENU_CONTACT | raw }}
                        </a>
                    </li>
                </ul>
                <ul id="nav_right_items" class="nav_right_items">
                    <li class="user_items">
                        <div id="user_logged_buttons">

                            {% if session[config['cookies_prefix']~'_UserGroup'] != '' %}
