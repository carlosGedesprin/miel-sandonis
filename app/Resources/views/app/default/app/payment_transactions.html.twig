{% extends 'app/' ~ config.app_skin ~ '/app.html.twig' %}

{% set entity = 'payment_transaction' %}
{% set folder = 'app' %}

{% block title %} {{ parent() }} &bull; {{ lang.PAYMENT_TRANSACTION }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- pagination css -->
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/pagination.css') }}" type="text/css" />
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/lists.css') }}" type="text/css" />
    <style>
        .pagination li.next a{
            background: url("/assets/images/app/{{ config.app_skin }}/icon_pagination_next.png");
        }
        .pagination li.previous a{
            background: url("/assets/images/app/{{ config.app_skin }}/icon_pagination_prev.png");
        }
    </style>
{% endblock %}

{% block body %}

    <div class="container-fluid">

        <div class="row">
            <div class="col-md-10 offset-1 my-4 p-2 rounded-3 bg-light font-weight-bold">
                {{ lang.PAYMENT_TRANSACTION }}
            </div>
        </div>

        <div class="row">
            <div class="col-md-10 offset-md-1">

                {% if session.alert %}
                    <div class="row" id="messages">
                        <div class="col-12">
                            <div class="alert alert-{{ session.alert.type }}">
                                {{ session.alert.message|raw }}
                            </div>
                        </div>
                    </div>
                    {{ deleteMessages() }}
                {% endif %}

                <div class="row no-gutters justify-content-between">
                    <div class="col-sm-12 col-md-2">
                        {#<button type="button" class="btn btn-info item-add" data-item="/{{ folder }}/{{ entity }}/edit/0">{{ lang.PAYMENT_TRANSACTION_ADD }}</button>#}
                    </div>
                    <div class="col-auto p-0">
                        {% include 'app/' ~ config.app_skin ~ '/common/list_filters.twig' %}
                    </div>
                </div>
                {% include 'app/' ~ config.app_skin ~ '/common/list_pagination.twig' %}

                <div class="row">
                    <div class="col-12">

                        <table class="table table-hover table-condensed">
                            <thead>
                                <tr>
                                    <th>
                                        {% set column_field = 'id' %}
                                        {% set column_name = '#' %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                    <th class="text-center">
                                        {% set column_field = 'date_reg' %}
                                        {% set column_name = lang.PAYMENT_TRANSACTION_DATE %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                    <th>
                                        {% set column_field = 'account' %}
                                        {% set column_name = lang.PAYMENT_TRANSACTION_ACCOUNT %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                    <th>
                                        {% set column_field = 'quote' %}
                                        {% set column_name = lang.PAYMENT_TRANSACTION_QUOTE %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                    <th>
                                        {% set column_field = 'funding' %}
                                        {% set column_name = lang.PAYMENT_TRANSACTION_FUNDING %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                    <th>
                                        {% set column_field = 'payment_type' %}
                                        {% set column_name = lang.PAYMENT_TRANSACTION_PAYMENT_TYPE %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                    <th>
                                        {% set column_field = 'origin_id' %}
                                        {% set column_name = lang.PAYMENT_TRANSACTION_ORIGIN %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                    <th>
                                        {% set column_field = 'transaction_id' %}
                                        {% set column_name = lang.PAYMENT_TRANSACTION_KEY %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                    <th>
                                        {% set column_field = 'result' %}
                                        {% set column_name = lang.PAYMENT_TRANSACTION_RESULT %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                    {#
                                    <th><span class="titleItem itemOptions" title="{{ lang.OPTIONS }}">{{ lang.OPTIONS }}</span></th>
                                    #}
                                </tr>
                            </thead>
                            <tbody>
                            {% if res %}
                                {% for item in res %}
                                    <tr class="item-edit-row">
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.id }}</td>
                                        <td class="item-edit text-center" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.date_reg | date("d-m-Y H:i:s") }}</td>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.account | getAccountName }}</td>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.quote }}</td>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.funding }}</td>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.payment_type | getPaymentTypeName }}</td>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.origin_id }}</td>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.transaction_id }}</td>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.id }}">{{ item.result }}</td>
                                        {#
                                        <td>
                                            <span data-item="/{{ folder }}/{{ entity }}/delete/{{ item.id }}" class="item-delete" aria-hidden="true" style="text-decoration: none" title="{{ lang.DELETE }}">
                                                <i class="{{ icon_delete }}" aria-hidden="true" title="{{ lang.DELETE }}"></i>
                                            </span>
                                        </td>
                                        #}
                                    </tr>
                                {% endfor %}
                            {% else %}
                                <tr><td colspan="5">{{ lang.PAYMENT_TRANSACTION_NOT_FOUND }}</td></tr>
                            {% endif %}
                        </table>
                    </div>
                </div>

            </div>{#<div class="col-md-10 offset-md-1">#}
        </div>{#<div class="row">#}

    </div>{#<div class="container-fluid">#}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/pagination.js') }}"></script>
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/messaging.js') }}"></script>
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/lists.js') }}"></script>
    <script>
    $(document).ready(function(){

    });
    (function($) {
        'use strict';

    })(jQuery);
    </script>

{% endblock %}