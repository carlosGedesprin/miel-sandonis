    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Organization",
            "name": "{{ config.web_name }}",
            "alternateName": "{{ config.web_name }} - {{ config.web_description }}",
            "url": "{{ env.protocol }}://{{ env.domain }}",
            "logo": "{{ env.protocol }}://{{ env.domain }}/assets/images/web/logo_with_text_hor.png",
            "image": "{{ env.protocol }}://{{ env.domain }}/assets/images/web/default/logo_with_text_hor.png",
            "description": "{{ lang.WEB_LDJSON_COMPANY_DESCRIPTION }}",
            "foundingDate": "2021-10-15",
            "founder": {
                "@type": "Person",
                "name": "Carlos Cusí"
            },
            "sameAs": [
                      {% if config.company_facebook != '' %}"{{ config.company_facebook }}",{% endif %}
                      {% if config.company_twitter != '' %}"{{ config.company_twitter }}",{% endif %}
                      {% if config.company_instagram != '' %}"{{ config.company_instagram }}",{% endif %}
                      {% if config.company_linkedin != '' %}"{{ config.company_linkedin }}",{% endif %}
                      {% if config.company_youtube != '' %}"{{ config.company_youtube }}",{% endif %}
                      {% if config.company_pinterest != '' %}"{{ config.company_pinterest }}"{% endif %}
            ],
            "contactPoint": [
                                {
                                    "@type": "ContactPoint",
                                    "telephone": "{{ config.web_info_phone }}",
                                    "contactType": "Customer Service",
                                    "areaServed": "{{ env.country }}",
                                    "availableLanguage": [
                                                          "Spanish",
                                                          "English"
                                                        ]
                                },
                                {
                                "@type": "ContactPoint",
                                "telephone": "{{ config.web_info_phone }}",
                                "contactType": "Techniocal Support",
                                "areaServed": "{{ env.country }}",
                                "availableLanguage": [
                                                      "Spanish",
                                                      "English"
                                                    ]
                                }
             ],
            "address": {
                "@type": "PostalAddress",
                "streetAddress": "{{ config.company_address_1 }}",
                "addressLocality": "{{ config.company_address_4 }}",
                "addressRegion": "{{ config.company_address_5 }}",
                "postalCode": "{{ config.company_postcode }}",
                "addressCountry": "{{ env.country }}"
            },
            "knowsAbout": [
                "{{ lang.WEB_LDJSON_COMPANY_KNOWSABOUT }}",
                "CHATGPT, COPILOT,CLAUDE, GEMINI, DEEPSEEK",
                "ZAPIER,MAKE, N8N, RAG"
            ]
        }
    </script>
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": "{{ config.web_name }}",
            "url": "{{ env.protocol }}://{{ env.domain }}",
            "inLanguage": "{{ env.lang }}",
            "potentialAction": {
                "@type": "SearchAction",
                "target": "{{ env.protocol }}://{{ env.domain }}/?s={search_term_string}",
                "query-input": "required name=search_term_string"
            },
            "sameAs": [
                      {% if config.company_facebook != '' %}"{{ config.company_facebook }}",{% endif %}
                      {% if config.company_twitter != '' %}"{{ config.company_twitter }}",{% endif %}
                      {% if config.company_instagram != '' %}"{{ config.company_instagram }}",{% endif %}
                      {% if config.company_linkedin != '' %}"{{ config.company_linkedin }}",{% endif %}
                      {% if config.company_youtube != '' %}"{{ config.company_youtube }}",{% endif %}
                      {% if config.company_pinterest != '' %}"{{ config.company_pinterest }}"{% endif %}
            ],
            "mainEntity": [
                {
                    "@type": "SiteNavigationElement",
                    "name": "Inicio",
                    "url": "{{ env.protocol }}://{{ env.domain }}",
                    "description": "Página principal con información general sobre Automatización de procesos empresariales.",
                    "potentialAction": {
                        "@type": "ViewAction",
                        "target": "{{ env.protocol }}://{{ env.domain }}",
                        "name": "Ver página de inicio"
                    }
                },
                {
                    "@type": "SiteNavigationElement",
                    "name": "Soluciones",
                    "url": "{{ env.protocol }}://{{ env.domain }}/solutions",
                    "description": "Soluciones para automatizar procesos.",
                    "potentialAction": {
                        "@type": "ViewAction",
                        "target": "{{ env.protocol }}://{{ env.domain }}/solutions",
                        "name": "Explorar soluciones de Automatizacion de procesos empresariales"
                    }
                },
                {
                    "@type": "SiteNavigationElement",
                    "name": "Conócenos",
                    "url": "{{ env.protocol }}://{{ env.domain }}/conocenos",
                    "description": "Información sobre equipo, misión y valores.",
                    "potentialAction": {
                        "@type": "ViewAction",
                        "target": "{{ env.protocol }}://{{ env.domain }}/conocenos",
                        "name": "Conoce quienes somos y porqué hacemos lo que hacemos"
                    }
                },
                {
                    "@type": "SiteNavigationElement",
                    "name": "Blog",
                    "url": "{{ env.protocol }}://{{ env.domain }}/blog",
                    "description": "Artículos y noticias sobre inteligencia artificial, soluciones de automatizaciones y tecnología relacionada.",
                    "potentialAction": {
                        "@type": "ViewAction",
                        "target": "{{ env.protocol }}://{{ env.domain }}/blog",
                        "name": "Leer el blog"
                    }
                },
                {
                    "@type": "SiteNavigationElement",
                    "name": "Contacto",
                    "url": "{{ env.protocol }}://{{ env.domain }}/contact",
                    "description": "Formulario y datos de contacto para consultas o colaboraciones.",
                    "potentialAction": {
                        "@type": "ViewAction",
                        "target": "{{ env.protocol }}://{{ env.domain }}/contact",
                        "name": "Contactar con un experto en automatización de procesos"
                    }
                }
            ]
        }
    </script>

    {% block ld_json %}{% endblock %}

    <title>{% block title %}{{ config.web_name }}{% if env.env_env == 'dev' %} · Dev · {{ server.SERVER_ADDR }}{% endif %}{% endblock %}</title>

