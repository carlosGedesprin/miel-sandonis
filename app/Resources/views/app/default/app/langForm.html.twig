{% extends 'app/' ~ config.app_skin ~ '/app.html.twig' %}

{% set entity = 'lang' %}

{% block title %} {{ parent() }} &bull; {% if (data.action == 'delete') %}{{ lang.LANG_DELETE }}{% elseif (data.action == 'edit') or data.action == 'add' %}{{ lang.LANG_EDIT }}{%  endif %}{% endblock %}

{% block body %}

    <div class="container-fluid mb-4">

        <a href="#" id="topofthepage"></a>

        <div class="col-md-8 offset-md-2 col-sm-12 my-4 p-2 rounded-3 font-weight-bold {% if (data.action == 'delete') %}is_delete{%  else %} bg-light{%  endif %}">
            {% if (data.action == 'delete') %}
                {{ lang.LANG_DELETE }}
            {% elseif (data.action == 'edit') %}
                {{ lang.LANG_EDIT }}
            {% elseif  (data.action == 'add') %}
                {{ lang.LANG_ADD }}
            {%  endif %}
            {% if (data.action != 'add') %}: {{ getLangName( reg.code_2a, session[config['cookies_prefix']~'_locale'] ) }}{%  endif %}
        </div>

        <div class="row">
            <div class="col-md-10 col-sm-12 mx-auto">

                <form id="item-form"
                      method="post"
                      role="form"
                      enctype="multipart/form-data"
                >

                    <div class="row">
                        <div class="col-md-10 col-sm-12 mx-auto">

                            <div id="box-result">
                                <div class="alert">
                                </div>
                            </div>

                            <div class="card">

                                <div class="card-header">
                                    <ul class="nav nav-tabs card-header-tabs" id="tabs-list" role="tablist">
                                        <li class="nav-item">
                                            <a class="nav-link active"
                                               id="details-tab"
                                               href="#tab-details"
                                               role="tab"
                                               aria-controls="details"
                                               aria-selected="true">
                                                {{ lang.LANG_TAB_DETAILS }}
                                            </a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link"
                                               id="names-tab"
                                               href="#tab-names"
                                               role="tab"
                                               aria-controls="names"
                                               aria-selected="false">
                                                {{ lang.LANG_TAB_NAMES }}
                                            </a>
                                        </li>
                                        {#
                                        {% if (data.action != 'add') %}
                                            {% if user_group == '1' or user_group == '2' %}
                                                <li class="nav-item">
                                                    <a class="nav-link"
                                                    id="register-tab"
                                                    href="#tab-register"
                                                    role="tab"
                                                    aria-controls="register"
                                                    aria-selected="false">
                                                        {{ lang.LANG_TAB_REGISTER }}
                                                    </a>
                                                </li>
                                            {% endif %}
                                        {% endif %}
                                        #}
                                    </ul>

                                </div>

                                <div class="card-body">

                                    {# This shines in all tab-content #}
                                    {% if data.action != 'add' and not reg.active %}
                                        <div class="row">
                                            <div class="col-9 mx-auto card-title-notactive">
                                                {{ lang.LANG_NOT_ACTIVE }}
                                            </div>
                                        </div>
                                    {% endif %}

                                    <div class="tab-content mt-3">

                                        <div class="tab-pane fade show active p-3 {% if data.action != 'add' and not reg.active %}reg_not_active{% else %}reg_active{% endif %}" id="tab-details" role="tabpanel" aria-labelledby="details-tab">

                                            {#<h5 class="card-title text-center">{{ lang.LANG_TAB_DETAILS }}</h5>#}

                                            <div class="row">
                                                <div class="col-md-8 offset-md-2">

                                                    <div class="form-group">
                                                        <label class="col-12" for="code_2a">{{ lang.LANG_CODE_2A }}:</label>
                                                        <input type="text"
                                                               class="form-control"
                                                               id="code_2a"
                                                               name="code_2a"
                                                               minlength="2"
                                                               maxlength="2"
                                                               {% if (data.action == 'delete') %}readonly="readonly"{%  endif %}
                                                               value="{{ reg.code_2a }}"
                                                               placeholder="{{ lang.ENTER_CODE }}"
                                                               aria-labelledby="code_2aAriaDesc">
                                                    </div>
                                                    <span id="code_2aAriaDesc" class="d-none">{{ lang.LANG_CODE_2A_DESC }}</span>

                                                    <div class="form-group">
                                                        <label class="col-12" for="code_3a">{{ lang.LANG_CODE_3A }}:</label>
                                                        <input type="text"
                                                               class="form-control"
                                                               id="code_3a"
                                                               name="code_3a"
                                                               minlength="3"
                                                               maxlength="3"
                                                               {% if (data.action == 'delete') %}readonly="readonly"{%  endif %}
                                                               value="{{ reg.code_3a }}"
                                                               placeholder="{{ lang.ENTER_CODE }}"
                                                               aria-labelledby="code_3aAriaDesc">
                                                    </div>
                                                    <span id="code_3aAriaDesc" class="d-none">{{ lang.LANG_CODE_3A_DESC }}</span>

                                                    <div class="form-group">
                                                        <label class="col-12" for="family">{{ lang.LANG_FAMILY }}:</label>
                                                        <input type="text"
                                                               class="form-control"
                                                               id="family"
                                                               name="family"
                                                               minlength="4"
                                                               maxlength="20"
                                                               {% if (data.action == 'delete') %}readonly="readonly"{%  endif %}
                                                               value="{{ reg.family }}"
                                                               placeholder="{{ lang.ENTER_NAME }}"
                                                               aria-labelledby="familyAriaDesc">
                                                    </div>
                                                    <span id="familyAriaDesc" class="d-none">{{ lang.LANG_FAMILY_DESC }}</span>

                                                    <div class="form-group">
                                                        <label class="col-12" for="iso_name">{{ lang.LANG_ISO_NAME }}:</label>
                                                        <input type="text"
                                                               class="form-control"
                                                               id="iso_name"
                                                               name="iso_name"
                                                               minlength="4"
                                                               maxlength="100"
                                                               {% if (data.action == 'delete') %}readonly="readonly"{%  endif %}
                                                               value="{{ reg.iso_name }}"
                                                               placeholder="{{ lang.ENTER_NAME }}"
                                                               aria-labelledby="iso_nameAriaDesc">
                                                    </div>
                                                    <span id="iso_nameAriaDesc" class="d-none">{{ lang.LANG_ISO_NAME_DESC }}</span>

                                                    <div class="form-group">
                                                        <label class="col-12" for="folder">{{ lang.LANG_FOLDER }}:</label>
                                                        <input type="text"
                                                               class="form-control"
                                                               id="folder"
                                                               name="folder"
                                                               minlength="2"
                                                               maxlength="10"
                                                               {% if (data.action == 'delete') %}readonly="readonly"{%  endif %}
                                                               value="{{ reg.folder }}"
                                                               placeholder="{{ lang.ENTER_FOLDER }}"
                                                               aria-labelledby="folderAriaDesc">
                                                    </div>
                                                    <span id="folderAriaDesc" class="d-none">{{ lang.LANG_FOLDER_DESC }}</span>

                                                    <div class="form-group row">
                                                        <div class="col-1 align-content-end">
                                                            <label class="switch align-self-start">
                                                                <input type="checkbox"
                                                                       class="switch_input"
                                                                       id="default"
                                                                       name="default"
                                                                       {% if (reg.default == '1') %}checked="checked"{%  endif %}
                                                                       value="{{ reg.default }}"
                                                                >
                                                                <span class="slider round"></span>
                                                            </label>
                                                        </div>
                                                        <div class="form-label col-10 ml-20 my-auto mx-right" for="default">{{ lang.LANG_DEFAULT }}</div>
                                                    </div>

                                                    <div class="form-group row">
                                                        <label class="col-12" for="active">{{ lang.LANG_ACTIVE }}:</label>
                                                        <select class="form-control"
                                                                id="active"
                                                                name="active"
                                                                {% if (data.action == 'delete') %}readonly="readonly"{%  endif %}
                                                                value="{{ reg.active }}"
                                                                placeholder="{{ lang.SELECT }}"
                                                                aria-labelledby="activeAriaDesc">
                                                            {{ data.active_options|raw }}
                                                        </select>
                                                    </div>
                                                    <span id="activeAriaDesc" class="d-none">{{ lang.LANG_ACTIVE_DESC }}</span>

                                                </div>{# <div class="col-md-8 offset-md-2"> #}
                                            </div>{# <div class="row"> #}

                                        </div>{# <div class="tab-pane fade show active p-3" id="details" role="tabpanel" aria-labelledby="details-tab"> #}

                                        <div class="tab-pane fade show p-3 {% if data.action != 'add' and not reg.active %}reg_not_active{% else %}reg_active{% endif %}" id="tab-names" role="tabpanel" aria-labelledby="names-tab">

                                            {#<h5 class="card-title text-center">{{ lang.LANG_TAB_NAMES }}</h5>#}

                                            <div class="row">
                                                <div class="col-md-8 offset-md-2">

                                                    {% if data.names %}
                                                        {% for name_field in data.names %}

                                                            <div class="form-group">
                                                                <label class="col-12" for="lang_name_{{ name_field.lang_code_2a }}">
                                                                    {% if ( name_field.lang_code_2a == 'this') %}
                                                                        {{ lang.LANG_THIS_LANG }}:
                                                                    {% elseif ( name_field.lang_code_2a == reg.code_2a ) %}
                                                                        {{ lang.LANG_THIS_LANG }} ({{ getLangName( name_field.lang_code_2a, reg.code_2a ) }}):
                                                                    {% else %}
                                                                        {{ getLangName( name_field.lang_code_2a, session[config['cookies_prefix']~'_locale'] ) }}:
                                                                    {% endif %}
                                                                </label>
                                                                <input type="text"
                                                                       class="form-control"
                                                                       id="lang_name_{{ name_field.lang_code_2a }}"
                                                                       name="lang_name[{{ name_field.lang_code_2a }}]"
                                                                       maxlength="100"
                                                                       {% if (data.action == 'delete') %}readonly="readonly"{%  endif %}
                                                                       value="{{ name_field.lang_name }}"
                                                                       placeholder="{{ lang.ENTER_NAME }}"
                                                                       aria-labelledby="name_{{ name_field.lang_code_2a }}AriaDesc">
                                                            </div>
                                                            <span id="name_{{ name_field.lang_code_2a }}AriaDesc" class="d-none">{{ lang.LANG_NAME_DESC }}</span>

                                                        {% endfor %}
                                                    {% endif %}

                                                </div>{# <div class="col-md-8 offset-md-2">#}
                                            </div>{# <div class="row"> #}

                                        </div>{# <div class="tab-pane fade show p-3" id="tab-names" role="tabpanel" aria-labelledby="names-tab"> #}

                                        {#
                                        {% if (data.action != 'add') %}
                                            {% if user_group == '1' or user_group == '2' %}

                                                <div class="tab-pane fade show p-3 {% if data.action != 'add' and not reg.active %}reg_not_active{% else %}reg_active{% endif %}" id="tab-register" role="tabpanel" aria-labelledby="register-tab">

                                                    {#<h5 class="card-title text-center">{{ lang.ENTITY_TAB_REGISTER }}</h5>

                                                    <div class="row">
                                                        <div class="col-md-8 offset-md-2">

                                                            <div class="form-group">
                                                                <label class="control-label" for="createdby">{{ lang.APP_CREATED_BY }}:</label>
                                                                {{ reg.createdby }}
                                                            </div>

                                                            <div class="form-group">
                                                                <label class="control-label" for="createddate">{{ lang.APP_CREATED_DATE }}:</label>
                                                                {{ reg.createddate }}
                                                            </div>

                                                            <div class="form-group">
                                                                <label class="control-label" for="updatedby">{{ lang.APP_UPDATED_BY }}:</label>
                                                                {{ reg.updatedby }}
                                                            </div>

                                                            <div class="form-group">
                                                                <label class="control-label" for="updateddate">{{ lang.APP_UPDATED_DATE }}:</label>
                                                                {{ reg.updateddate }}
                                                            </div>

                                                        </div>{# <div class="col-md-8 offset-md-2">
                                                    </div>{# <div class="row">

                                                </div>{# <div class="tab-pane fade show p-3" id="tab-register" role="tabpanel" aria-labelledby="register-tab">
                                            {% endif %}
                                        {% endif %}
                                        #}

                                    </div>{# <div class="tab-content mt-3"> #}

                                </div>{# <div class="card-body"> #}
                            </div>{# <div class="card"> #}

                        </div>{# <div class="col-8 mx-auto"> #}
                    </div>{# <div class="row"> #}

                    <div class="row">
                        <div class="col-12 my-4 text-center">
                            <button type="button" name="btn_submit" id="btn_submit" class="btn btn-info">{% if (data.action == 'delete') %}{{ lang.DELETE }}{% elseif (data.action == 'edit') or data.action == 'add' %}{{ lang.SAVE }}{%  endif %}</button>
                            <button type="button" name="btn_cancel" id="btn_cancel" class="btn btn-info" formnovalidate>{{ lang.BACK_TO_LIST }}</button>
                        </div>
                    </div>
                    <input type="hidden" name="id" value="{{ reg.id }}">

                    {# Filters #}
                    {% for filter_name, filter_data in filters %}
                        {% for filter_data_key, filter_data_data in filter_data %}
                            <input type="hidden" name="filters[{{ filter_name }}][{{ filter_data_key }}]" id="filter_{{ filter_name }}_{{ filter_data_key }}" value="{{ filter_data_data }}" />
                        {% endfor %}
                    {% endfor %}
                    {# Pagination #}
                    {% for key, value in pagination %}
                        <input type="hidden" name="pagination[{{ key }}]" id="{{ key }}" value="{{ value }}" />
                    {% endfor %}

                    <input type="hidden" name="auth_token" value="{{ data.auth_token }}" />

                </form>

            </div>{# <div class="col-10 mx-auto"> #}
        </div>{# <div class="row">#}

    </div>{# <div class="container-fluid mb-4">#}

    <div class="clear"></div>

{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/form.css') }}" type="text/css" />
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/input_switch.css') }}" type="text/css" />
{% endblock %}
{% block javascripts %}
     {{ parent() }}
    <script>
        $(document).ready(function(){
            {# app/langForm.html.twig #}

        });
        (function($) {
            'use strict';

        })(jQuery);
    </script>
    <script type="text/javascript">
        var folder = '{{ session[config['cookies_prefix']~'_folder'] }}';
        var entity = '{{ entity }}';
        var action = '{{ data.action }}';
        var cancel = '{{ cancel }}';
        var reg_id = '{{ reg.id }}';
        var l_errors_found = '{{ lang.ERRORS_FOUND }}';
        var l_form_has_errors = '{{ lang.ERRORS_FORM }}';
    </script>
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/forms.js') }}"></script>
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/input_switch.js') }}"></script>
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/scrool-to-top.js') }}"></script>
{% endblock %}
