{% extends 'app/' ~ config.app_skin ~ '/app.html.twig' %}

{% set entity = 'city' %}
{% set folder = 'app' %}

{% block title %} {{ parent() }} &bull; {{ lang.CITIES }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- pagination css -->
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/pagination.css') }}" type="text/css" />
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/lists.css') }}" type="text/css" />
    <style>
        .pagination li.next a{
            background: url("/assets/images/app/{{ config.app_skin }}/icon_pagination_next.png");
        }
        .pagination li.previous a{
            background: url("/assets/images/app/{{ config.app_skin }}/icon_pagination_prev.png");
        }
    </style>
{% endblock %}

{% block body %}

    <div class="container-fluid">

        <div class="row">
            <div class="col-md-10 offset-1 my-4 p-2 rounded-3 bg-light font-weight-bold">
                {{ lang.CITIES }}
            </div>
        </div>

        <div class="row">
            <div class="col-md-10 offset-md-1">

                {% if session.alert %}
                    <div class="row" id="messages">
                        <div class="col-12">
                            <div class="alert alert-{{ session.alert.type }}">
                                {{ session.alert.message|raw }}
                            </div>
                        </div>
                    </div>
                    {{ deleteMessages() }}
                {% endif %}

                <div class="row no-gutters justify-content-between">
                    <div class="col-sm-12 col-md-2">
                        <button type="button" class="btn btn-info item-add" data-item="/{{ folder }}/{{ entity }}/edit/0">{{ lang.CITY_ADD }}</button>
                    </div>
                    <div class="col-auto p-0">
                        {% include 'app/' ~ config.app_skin ~ '/common/list_filters.twig' %}
                    </div>
                </div>
                {% include 'app/' ~ config.app_skin ~ '/common/list_pagination.twig' %}

                <div class="row">
                    <div class="col-12">

                        <table class="table table-hover table-condensed">
                            <thead>
                            <tr>
                                <th>
                                    {% set column_field = 'id' %}
                                    {% set column_name = '#' %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>
                                <th>
                                    {% set column_field = 'name' %}
                                    {% set column_name = lang.CITY_NAME %}
                                    <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                    {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                        <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                    {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                        <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                    {% endif %}
                                </th>
                                {% if filters['country_code_2a']['value'] == '' %}
                                    <th>
                                        {% set column_field = 'country_code_2a' %}
                                        {% set column_name = lang.COUNTRY %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                {% endif %}
                                {% if filters['region_code']['value'] == '' %}
                                    <th>
                                        {% set column_field = 'region_code' %}
                                        {% set column_name = lang.REGION %}
                                        <span class="titleItem" data-order-by="{{ column_field }}" title="{{ column_name }}">{{ column_name }}</span>
                                        {% if pagination.order == column_field and pagination.order_dir == "ASC" %}
                                            <button class="order_dir"><i class="{{ thumbs_up }}"></i></button>
                                        {% elseif pagination.order == column_field and pagination.order_dir == "DESC" %}
                                            <button class="order_dir"><i class="{{ thumbs_down }}"></i></button>
                                        {% endif %}
                                    </th>
                                {% endif %}
                                <th>Opt</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% if res %}
                                {% for item in res %}
                                    <tr class="item-edit-row">
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.city_code }}">{{ item.id }}</td>
                                        <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.city_code }}">{{ item.name | raw }}</td>
                                        {% if filters['country_code_2a']['value'] == '' %}
                                            <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.city_code }}">{{ item.country_name }}</td>
                                        {% endif %}
                                        {% if filters['region_code']['value'] == '' %}
                                            <td class="item-edit" data-item="/{{ folder }}/{{ entity }}/edit/{{ item.city_code }}">{{ item.region_name }}</td>
                                        {% endif %}
                                        <td>
                                            <span data-item="/{{ folder }}/{{ entity }}/delete/{{ item.city_code }}" class="item-delete" style="text-decoration: none" title="{{ lang.DELETE }}">
                                                <i class="{{ icon_delete }}" aria-hidden="true" title="{{ lang.DELETE }}"></i>
                                            </span>
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% else %}
                                <tr><td colspan="5">{{ lang.REGION_CITIES_NOT_FOUND }}</td></tr>
                            {% endif %}
                        </table>
                    </div>
                </div>

            </div>{#<div class="col-md-10 offset-md-1">#}
        </div>{#<div class="row">#}

    </div>{#<div class="container-fluid">#}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/pagination.js') }}"></script>
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/messaging.js') }}"></script>
    <script type="text/javascript" src="{{ asset_version('/assets/js/app/'~config.app_skin~'/lists.js') }}"></script>
    <script>
    $(document).ready(function(){

    });
    (function($) {

        'use strict';

        $('#filter_country_value').change(function() {
            $('#filter_region_value').val('0');
            $('#num_page').val('1');
            $('#listform').submit();
        });
        $('#filter_region_value').change(function() {
            $('#num_page').val('1');
            $('#listform').submit();
        });
    })(jQuery);
    </script>

{% endblock %}