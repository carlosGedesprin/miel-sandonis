{% extends 'app/' ~ config.app_skin ~ '/app.html.twig' %}

{% set entity = 'payment' %}

{% block title %} {{ parent() }} &bull; {% if (data.action == 'delete') %}{{ lang.PAYMENT_DELETE }}{% elseif (data.action == 'edit') or data.action == 'add' %}{{ lang.PAYMENT_EDIT }}{%  endif %}{% endblock %}

{% block body %}

<div class="container-fluid mb-4">

    <a href="#" id="topofthepage"></a>

    <div class="col-md-8 offset-md-2 col-sm-12 my-4 p-2 rounded-3 font-weight-bold {% if (data.action == 'delete') %}is_delete{%  else %} bg-light{%  endif %}">
        {% if (data.action == 'delete') %}
            {{ lang.PAYMENT_DELETE }}
        {% elseif (data.action == 'edit') %}
            {{ lang.PAYMENT_EDIT }}
        {% elseif  (data.action == 'add') %}
            {{ lang.PAYMENT_ADD }}
        {%  endif %}
        : {{ reg.name }}
    </div>

    <div class="row">
        <div class="col-md-10 col-sm-12 mx-auto">

            <form id="item-form"
                  method="post"
                  role="form"
                  enctype="multipart/form-data"
            >

                <div class="row">
                    <div class="col-md-10 col-sm-12 mx-auto">

                        <div id="box-result">
                            <div class="alert">
                            </div>
                        </div>

                        <div class="card">

                            <div class="card-header">
                                <ul class="nav nav-tabs card-header-tabs" id="tabs-list" role="tablist">
                                    <li class="nav-item">
                                        <a class="nav-link active"
                                           id="details-tab"
                                           href="#tab-details"
                                           role="tab"
                                           aria-controls="details"
                                           aria-selected="true">
                                            {{ lang.PAYMENT_TAB_DETAILS }}
                                        </a>
                                    </li>
                                    {#
                                    {% if (data.action != 'add') %}
                                        {% if user_group == '1' or user_group == '2' %}
                                            <li class="nav-item">
                                                <a class="nav-link"
                                                   id="register-tab"
                                                   href="#tab-register"
                                                   role="tab"
                                                   aria-controls="register"
                                                   aria-selected="false">
                                                    {{ lang.PAYMENT_TAB_REGISTER }}
                                                </a>
                                            </li>
                                        {% endif %}
                                    {% endif %}
                                    #}
                                </ul>
                            </div>

                            <div class="card-body">

                                {# This shines in all tab-content #}
                                {# {% if data.action != 'add' and not reg.active %}
                                    <div class="row">
                                        <div class="col-9 mx-auto card-title-notactive">
                                            {{ lang.PAYMENT_NOT_ACTIVE }}
                                        </div>
                                    </div>
                                {% endif %} #}

                                <div class="tab-content mt-3">

                                    <div class="tab-pane fade show active p-3 {% if data.action != 'add' and not reg.result %}reg_not_active{% else %}reg_active{% endif %}" id="tab-details" role="tabpanel" aria-labelledby="details-tab">

                                        {#<h5 class="card-title text-center">{{ lang.LANG_TEXT_TAB_DETAILS }}</h5>#}

                                        <div class="row">
                                            <div class="col-md-8 offset-md-2">

                                                <div class="form-group">
                                                    <label class="col-12" for="account">{{ lang.PAYMENT_ACCOUNT }}:</label>
                                                    <select class="form-control"
                                                            id="account"
                                                            name="account"
                                                            disabled="disabled"
                                                            value="{{ reg.account }}"
                                                            placeholder="{{ lang.ACCOUNT_SELECT }}"
                                                            aria-labelledby="accountAriaDesc">
                                                        {{ data.account_options | raw }}
                                                    </select>
                                                </div>
                                                <span id="accountAriaDesc" class="d-none">{{ lang.PAYMENT_ACCOUNT_DESC }}</span>

                                                <div class="form-group">
                                                    <label class="col-12" for="quote">{{ lang.PAYMENT_QUOTE }}:</label>
                                                    <select class="form-control"
                                                            id="quote"
                                                            name="quote"
                                                            disabled="disabled"
                                                            value="{{ reg.quote }}"
                                                            placeholder="{{ lang.QUOTE_SELECT }}"
                                                            aria-labelledby="quoteAriaDesc">
                                                        {{ data.quote_options | raw }}
                                                    </select>
                                                </div>
                                                <span id="quoteAriaDesc" class="d-none">{{ lang.PAYMENT_QUOTE_DESC }}</span>

                                                <div class="form-group">
                                                    <label class="col-12" for="payment_type">{{ lang.PAYMENT_TYPE }}:</label>
                                                    <select class="form-control"
                                                            id="payment_type"
                                                            name="payment_type"
                                                            disabled="disabled"
                                                            value="{{ reg.payment_type }}"
                                                            placeholder="{{ lang.PAYMENT_TYPE_SELECT }}"
                                                            aria-labelledby="paymenttypeAriaDesc">
                                                        {{ data.payment_type_options | raw }}
                                                    </select>
                                                </div>
                                                <span id="paymenttypeAriaDesc" class="d-none">{{ lang.PAYMENT_TYPE_DESC }}</span>

                                                <div class="form-group">
                                                    <label class="col-12" for="instalment">{{ lang.PAYMENT_INSTALMENT }}:</label>
                                                     <input type="number"
                                                            class="form-control"
                                                            id="instalment"
                                                            name="instalment"
                                                            disabled="disabled"
                                                            value="{{ reg.instalment }}"
                                                            placeholder="{{ lang.PAYMENT_ENTER_INSTALMENT }}"
                                                            aria-labelledby="instalmentAriaDesc">
                                                        {{ data.instalment_options | raw }}
                                                    </select>
                                                </div>
                                                <span id="instalmentAriaDesc" class="d-none">{{ lang.PAYMENT_INSTALMENT_DESC }}</span>

                                                <div class="form-group">
                                                    <label class="col-12" for="date">{{ lang.PAYMENT_DATE }}:</label>
                                                    <div id="date_datepicker" class="input-group date datepicker">
                                                        <input type="text"
                                                               class="form-control"
                                                               id="date"
                                                               name="date"
                                                               minlength="4"
                                                               maxlength="18"
                                                               disabled="disabled"
                                                               value="{{ reg.date }}"
                                                               placeholder="{{ lang.PAYMENT_ENTER_DATE }}">
                                                        <span class="input-group-append">
                                                            <span class="input-group-text bg-white d-block">
                                                                <i class="fa fa-calendar"></i>
                                                            </span>
                                                        </span>
                                                    </div>
                                                </div>

                                                <div class="form-group">
                                                    <label class="col-12" for="amount">{{ lang.PAYMENT_AMOUNT }}:</label>
                                                    <div class="input-group mb-3">
                                                        <input type="text"
                                                            class="form-control money"
                                                            id="amount"
                                                            name="amount"
                                                            minlength="1"
                                                            maxlength="11"
                                                            disabled="disabled"
                                                            value="{{ reg.amount }}"
                                                            placeholder="{{ lang.ENTER_AMOUNT }}">
                                                    </div>
                                                </div>

                                                <div class="form-group">
                                                    <label class="col-12" for="result">{{ lang.PAYMENT_RESULT }}:</label>
                                                    <select class="form-control"
                                                            id="result"
                                                            name="result"
                                                            disabled="disabled"
                                                            value="{{ reg.result }}"
                                                            placeholder="{{ lang.PAYMENT_RESULT_SELECT }}"
                                                            aria-labelledby="resultAriaDesc">
                                                        {{ data.result_options | raw }}
                                                    </select>
                                                </div>
                                                <span id="resultAriaDesc" class="d-none">{{ lang.PAYMENT_RESULT_DESC }}</span>

                                                <div class="form-group">
                                                    <label class="col-12" for="type_trans">{{ lang.PAYMENT_TYPE_TRANS }}:</label>
                                                    <div class="input-group mb-3">
                                                        <input type="text"
                                                            class="form-control"
                                                            id="type_trans"
                                                            name="type_trans"
                                                            minlength="1"
                                                            maxlength="50"
                                                            disabled="disabled"
                                                            value="{{ reg.typeTrans }}"
                                                            placeholder="{{ lang.PAYMENT_ENTER_TYPE_TRANS }}">
                                                    </div>
                                                </div>
                                                
                                                {% if data.action == 'add'%}
                                                    <div class="form-group">
                                                        <label class="col-12" for="id_trans">{{ lang.PAYMENT_ID_TRANS }}:</label>
                                                        <div class="input-group mb-3">
                                                            <input type="text"
                                                                class="form-control"
                                                                id="id_trans"
                                                                name="id_trans"
                                                                minlength="1"
                                                                maxlength="50"
                                                                disabled="disabled"
                                                                value="{{ reg.idTrans }}"
                                                                placeholder="{{ lang.PAYMENT_ENTER_ID_TRANS }}">
                                                        </div>
                                                    </div>
                                                {% else %}
                                                    <input type="hidden" name="id_trans" value="{{ reg.idTrans }}" />
                                                {% endif %}

                                                <div class="form-group">
                                                    <label class="col-12" for="cod_aproval">{{ lang.PAYMENT_COD_APROVAL }}:</label>
                                                    <div class="input-group mb-3">
                                                        <input type="text"
                                                            class="form-control"
                                                            id="cod_aproval"
                                                            name="cod_aproval"
                                                            minlength="1"
                                                            maxlength="50"
                                                            disabled="disabled"
                                                            value="{{ reg.codAproval }}"
                                                            placeholder="{{ lang.PAYMENT_ENTER_COD_APROVAL }}">
                                                    </div>
                                                </div>
                                                
                                                <div class="form-group">
                                                    <label class="col-12" for="cod_error">{{ lang.PAYMENT_COD_ERROR }}:</label>
                                                    <div class="input-group mb-3">
                                                        <input type="text"
                                                            class="form-control"
                                                            id="cod_error"
                                                            name="cod_error"
                                                            minlength="1"
                                                            maxlength="50"
                                                            disabled="disabled"
                                                            value="{{ reg.codError }}"
                                                            placeholder="{{ lang.PAYMENT_ENTER_COD_ERROR }}">
                                                    </div>
                                                </div>
                                                
                                                <div class="form-group">
                                                    <label class="col-12" for="des_error">{{ lang.PAYMENT_DES_ERROR }}:</label>
                                                    <div class="input-group mb-3">
                                                        <textarea class="form-control"
                                                                  id="des_error"
                                                                  name="des_error"
                                                                  minlength="1"
                                                                  maxlength="50"
                                                                  disabled="disabled"
                                                                  value="{{ reg.desError }}"
                                                                  placeholder="{{ lang.PAYMENT_ENTER_DES_ERROR }}">
                                                        </textarea>
                                                    </div>
                                                </div>

                                            </div>{# <div class="col-md-8 offset-md-2"> #}
                                        </div>{# <div class="row"> #}

                                    </div>{# <div class="tab-pane fade show active p-3" id="tab-details" role="tabpanel" aria-labelledby="details-tab"> #}
                                    {#
                                    {% if (data.action != 'add') %}
                                        {% if user_group == '1' or user_group == '2' %}

                                            <div class="tab-pane fade show p-3 {% if data.action != 'add' and not reg.active %}reg_not_active{% else %}reg_active{% endif %}" id="tab-register" role="tabpanel" aria-labelledby="register-tab">

                                                {#<h5 class="card-title text-center">{{ lang.LANG_TEXT_TAB_REGISTER }}</h5>

                                                <div class="col-9 mx-auto">
                                                    <div class="row">

                                                        <div class="form-group" style="width: 100%;">
                                                            <label class="control-label" for="createdby">{{ lang.APP_CREATED_BY }}:</label>
                                                            {{ reg.createdby }}
                                                        </div>

                                                        <div class="form-group" style="width: 100%;">
                                                            <label class="control-label" for="createddate">{{ lang.APP_CREATED_DATE }}:</label>
                                                            {{ reg.createddate }}
                                                        </div>

                                                        <div class="form-group" style="width: 100%;">
                                                            <label class="control-label" for="updatedby">{{ lang.APP_UPDATED_BY }}:</label>
                                                            {{ reg.updatedby }}
                                                        </div>

                                                        <div class="form-group" style="width: 100%;">
                                                            <label class="control-label" for="updateddate">{{ lang.APP_UPDATED_DATE }}:</label>
                                                            {{ reg.updateddate }}
                                                        </div>

                                                    </div>{# <div class="row">
                                                </div>{# <div class="col-9 mx-auto">

                                            </div>{# <div class="tab-pane fade show p-3" id="tab-register" role="tabpanel" aria-labelledby="register-tab">

                                        {% endif %}
                                    {% endif %}
                                    #}

                                </div>{# <div class="tab-content mt-3"> #}

                            </div>{# <div class="card-body"> #}
                        </div>{# <div class="card"> #}

                    </div>{# <div class="col-8 mx-auto"> #}
                </div>{# <div class="row"> #}

                <div class="row">
                    <div class="col-12 my-4 text-center">
                        <button type="button" name="btn_submit" id="btn_submit" class="btn btn-primary" value="1">{% if (data.action == 'delete') %}{{ lang.DELETE }}{% elseif (data.action == 'edit') or data.action == 'add' %}{{ lang.SAVE }}{%  endif %}</button>
                        <button type="button" name="btn_cancel" id="btn_cancel" class="btn btn-info" formnovalidate>{{ lang.BACK_TO_LIST }}</button>
                    </div>
                </div>
                <input type="hidden" name="id" value="{{ reg.id }}">
                <input type="hidden" name="payment_key" value="{{ reg.payment_key }}">

                {# Filters #}
                {% for filter_name, filter_data in filters %}
                    {% for filter_data_key, filter_data_data in filter_data %}
                        <input type="hidden" name="filters[{{ filter_name }}][{{ filter_data_key }}]" id="filter_{{ filter_name }}_{{ filter_data_key }}" value="{{ filter_data_data }}" />
                    {% endfor %}
                {% endfor %}
                {# Pagination #}
                {% for key, value in pagination %}
                    <input type="hidden" name="pagination[{{ key }}]" id="{{ key }}" value="{{ value }}" />
                {% endfor %}

                <input type="hidden" name="auth_token" value="{{ data.auth_token }}" />

            </form>

        </div>{# <div class="col-10 mx-auto"> #}
    </div>{# <div class="row">#}

</div>{# <div class="container-fluid mb-4">#}

<div class="clear"></div>

{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css" type="text/css" />
    <link rel="stylesheet" href="{{ asset_version('/assets/css/app/'~config.app_skin~'/form.css') }}" type="text/css" />
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/locales/bootstrap-datepicker.es.min.js"></script>

    <script>
        $(document).ready(function(){
            {# app/paymentForm.html.twig #}

            $('.money').mask('000.000.000,00', {reverse: true});

            let today = new Date();

            $('.datepicker').datepicker({
                language: 'es',
                format: 'dd-mm-yyyy',
                todayBtn: true,
                todayHighlight: true,
                startDate: today,
                autoclose: true,
            });

        });
        (function($) {
            'use strict';

            $('#btn_submit').click(function(e) {

                $('#amount').css('display', 'none');
                var amount = $('#amount').cleanVal();
                $('#amount').val(amount);

            });

        })(jQuery);
    </script>
    <script type="text/javascript">
        var folder = '{{ session[config['cookies_prefix']~'_folder'] }}';
        var entity = '{{ entity }}';
        var action = '{{ data.action }}';
        var cancel = '{{ cancel }}';
        var reg_id = '{{ reg.id }}';
        var l_errors_found = '{{ lang.ERRORS_FOUND }}';
        var l_form_has_errors = '{{ lang.ERRORS_FORM }}';
    </script>
    <script type="text/javascript" src="/assets/js/app/{{ config.app_skin }}/forms.js"></script>
    <script type="text/javascript" src="/assets/js/app/{{ config.app_skin }}/jquery.mask.js"></script>
    <script type="text/javascript" src="/assets/js/app/{{ config.app_skin }}/scrool-to-top.js"></script>
{% endblock %}
