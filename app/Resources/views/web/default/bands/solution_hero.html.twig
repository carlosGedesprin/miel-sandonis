{% set path = '/assets/images/web/'~config.website_skin~'/bands/solutions_hero/' %}
{% set img_1 = path ~ 'solution_hero.png' %}

<section id="solution_hero" class="web_section">
    <div id="solution_hero_container" class="web_container">
        <div id="solution_hero_content" class="web_content">

            <div id="solution_hero_wrapper" class="web_wrapper">
                <div id="solution_hero_left">
                    <h1>
                        {{ data.hero_h1 | raw }} {#Automatización de facturas con IA#}
                    </h1>
                    <h2>
                        {{ data.hero_h2 | raw }} {#Convierte fotos de facturas en asientos contables en segundos#}
                    </h2>
                    <p>
                        {{ data.hero_p | raw }} {#Tu equipo envía las facturas por WhatsApp o Telegram. Nuestra IA las lee, valida y envía los datos directamente a tu software contable: sin teclear, sin copiar y pegar, sin errores.#}
                    </p>
                    <div id="solution_hero_buttons" class="generic_button">
                        <a
                           class="solution_hero_button"
                           href="/{{ lang.WEB_MENU_CONTACT_LINK }}"
                           title="{{ lang.WEB_TITLE_CONTACT }}"
                        >
                            {{ lang.WEB_SOLUTION_HERO_4 | raw }} {#Solicita una consultoría#}
                        </a>
                    </div>
                </div>
                <div id="solution_hero_right">
                    <img
                         src="{{ img_1 }}"
                         decoding="async"
                         alt=""
                    >
                </div>
            </div>

        </div>
    </div>
</section>