                                <div id="site_logout" class="header_action_buttons nav-item">
                                    <a href="/{{ lang.APP_LOGOUT_LINK }}"
                                       class="log-icon header_action_buttons_link"
                                       title="{{ lang.WEB_MENU_LOGOUT_TITLE }}">
                                        {#
                                        <div class="header_action_buttons_text">
                                            {{ lang.WEB_MENU_LOGOUT }}
                                        </div>
                                        #}
